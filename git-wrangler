#!/bin/bash

# Git-Wrangler dispatcher — routes subcommands to libexec/git-wrangler-<subcommand>

SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
    DIR_OF_SOURCE="$( cd -P "$( dirname "$SOURCE" )" && pwd )"
    SOURCE="$( readlink "$SOURCE" )"
    [[ $SOURCE != /* ]] && SOURCE="$DIR_OF_SOURCE/$SOURCE"
done
DIR="$( cd -P "$( dirname "$SOURCE" )" && pwd )"

subcommand="${1:-help}"

# Validate subcommand contains no path separators
if [[ "$subcommand" == */* || "$subcommand" == *\\* ]]; then
    printf "\e[31mError: Invalid subcommand '%s'. Subcommand must not contain path separators.\e[0m\n" "$subcommand" >&2
    exit 1
fi

target="$DIR/libexec/git-wrangler-$subcommand"

if [ -f "$target" ]; then
    exec bash "$target" "${@:2}"
else
    printf "\e[31mError: Unknown subcommand '%s'. Run 'git-wrangler help' for a list of available commands.\e[0m\n" "$subcommand" >&2
    exit 1
fi
