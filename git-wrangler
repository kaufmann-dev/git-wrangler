#!/bin/bash

# Git-Wrangler dispatcher — routes subcommands to libexec/git-wrangler-<subcommand>

SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
    DIR_OF_SOURCE="$( cd -P "$( dirname "$SOURCE" )" && pwd )"
    SOURCE="$( readlink "$SOURCE" )"
    [[ $SOURCE != /* ]] && SOURCE="$DIR_OF_SOURCE/$SOURCE"
done
DIR="$( cd -P "$( dirname "$SOURCE" )" && pwd )"

# shellcheck source=libexec/git-wrangler-ui
source "$DIR/libexec/git-wrangler-ui"

subcommand="${1:-help}"

# Validate subcommand contains no path separators
if [[ "$subcommand" == */* || "$subcommand" == *\\* ]]; then
    gw_error "Invalid subcommand '$subcommand'. Subcommand must not contain path separators."
    exit 1
fi

target="$DIR/libexec/git-wrangler-$subcommand"

if [ -f "$target" ] && awk '/^# Category:/{found=1} END{exit found ? 0 : 1}' "$target"; then
    exec bash "$target" "${@:2}"
else
    gw_error "Unknown subcommand '$subcommand'. Run 'git-wrangler help' for a list of available commands."
    exit 1
fi
