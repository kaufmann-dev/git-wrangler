#!/bin/sh

SOURCE=$0
while [ -L "$SOURCE" ]; do
    DIR_OF_SOURCE=$(cd -P "$(dirname "$SOURCE")" && pwd)
    LINK_TARGET=$(readlink "$SOURCE")
    case "$LINK_TARGET" in
        /*) SOURCE=$LINK_TARGET ;;
        *) SOURCE=$DIR_OF_SOURCE/$LINK_TARGET ;;
    esac
done

DIR=$(cd -P "$(dirname "$SOURCE")" && pwd)
ORIGINAL_CWD=$(pwd)

GIT_WRANGLER_INSTALL_DIR=$DIR
GIT_WRANGLER_LIBEXEC_DIR=$DIR/libexec
GIT_WRANGLER_ORIGINAL_CWD=$ORIGINAL_CWD
export GIT_WRANGLER_INSTALL_DIR GIT_WRANGLER_LIBEXEC_DIR GIT_WRANGLER_ORIGINAL_CWD

cd "$DIR" || exit 1

CACHE_ROOT=${XDG_CACHE_HOME:-"$HOME/.cache"}
CACHE_DIR=$CACHE_ROOT/git-wrangler
BIN=$CACHE_DIR/git-wrangler-go

needs_build=0
if [ ! -x "$BIN" ]; then
    needs_build=1
elif find "$DIR/go.mod" "$DIR/cmd" -type f -newer "$BIN" -print -quit | grep -q .; then
    needs_build=1
fi

if [ "$needs_build" -eq 1 ]; then
    GO_CMD=$(command -v go 2>/dev/null || true)
    if [ -z "$GO_CMD" ] && [ -x /usr/local/go/bin/go ]; then
        GO_CMD=/usr/local/go/bin/go
    fi
    if [ -z "$GO_CMD" ]; then
        printf "Error: go is required to build Git Wrangler.\n" >&2
        exit 1
    fi
    mkdir -p "$CACHE_DIR" || exit 1
    "$GO_CMD" build -buildvcs=false -o "$BIN" ./cmd/git-wrangler || exit 1
fi

exec "$BIN" "$@"
