#!/bin/bash

# ====
# Usage: git-wrangler rename-branch --oldbranch <old_name> --newbranch <new_name>
# Description: Renames a specified branch to a new name across repositories
# Category: Local Operations
#
# Renames a specified branch to a new name across all managed Git repositories.
# Repositories where the old branch does not exist or the new branch name is
# already taken are skipped automatically.
#
# Options:
#   --oldbranch <old_name>  (required) The name of the existing branch to rename.
#   --newbranch <new_name>  (required) The new name for the branch.
#
# Example:
#     git-wrangler rename-branch --oldbranch master --newbranch main
# ====

UI_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
# shellcheck source=libexec/git-wrangler-ui
source "$UI_DIR/git-wrangler-ui"


oldbranch=""
newbranch=""

# Parse command-line arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --oldbranch)
            oldbranch="$2"
            shift 2
            ;;
        --newbranch)
            newbranch="$2"
            shift 2
            ;;
        *)
            gw_error "Unknown option: $1"
            exit 1
            ;;
    esac
done

# Validate required arguments
if [[ -z "$oldbranch" || -z "$newbranch" ]]; then
    printf "${GW_RED}Error: Both --oldbranch and --newbranch options must be provided.${GW_RESET}\n" >&2
    exit 1
fi

# Check prerequisites
if ! command -v git &> /dev/null; then
    printf "${GW_RED}Error: 'git' is required for rename-branch. Run 'git-wrangler doctor' for more information.${GW_RESET}\n" >&2
    exit 1
fi

# Find target repositories
git_repositories=$(find . -maxdepth 2 -type d -name '.git')

if [ -z "$git_repositories" ]; then
    gw_warn "No Git repositories found in the specified directory."
    exit 0
fi

# Iterate through each repository
while IFS= read -r git_dir; do
    (
        # Get repository directory and name
        repo_dir=$(dirname "$git_dir")

        if [ "$repo_dir" = "." ]; then
            repo_name_display="${PWD##*/}"
        else
            repo_name_display=$(basename "$repo_dir")
        fi

        # Validate Git repository accessibility
        if ! cd "$repo_dir" >/dev/null 2>&1; then
            printf "${GW_RED}Error: Directory is inaccessible: %s${GW_RESET}\n" "$repo_name_display" >&2
            exit 1
        fi

        if ! git_output=$(git rev-parse --is-inside-work-tree 2>&1); then
            printf "${GW_RED}Error: Not a valid git repository for %s:\n%s${GW_RESET}\n" "$repo_name_display" "$git_output" >&2
            exit 1
        fi

        # Check if the old branch exists
        if ! git rev-parse --verify --quiet "refs/heads/$oldbranch" >/dev/null 2>&1; then
            printf "${GW_YELLOW}Old branch '%s' does not exist in %s. Skipping...${GW_RESET}\n" "$oldbranch" "$repo_name_display"
            exit 0
        fi

        # Check if the new branch name is already taken
        if git rev-parse --verify --quiet "refs/heads/$newbranch" >/dev/null 2>&1; then
            printf "${GW_YELLOW}New branch '%s' already exists in %s. Skipping...${GW_RESET}\n" "$newbranch" "$repo_name_display"
            exit 0
        fi

        # Perform branch rename
        if rename_output=$(git branch -m "$oldbranch" "$newbranch" 2>&1); then
            printf "${GW_GREEN}Branch renamed from '%s' to '%s' for %s${GW_RESET}\n" "$oldbranch" "$newbranch" "$repo_name_display"
        else
            printf "${GW_RED}Error: Failed to rename branch in %s:\n%s${GW_RESET}\n\n" "$repo_name_display" "$rename_output" >&2
        fi
    )
done <<< "$git_repositories"
