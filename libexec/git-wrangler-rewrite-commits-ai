#!/bin/bash

# ====
# Usage: git-wrangler rewrite-commits-ai --base-url <url> --model <model> [options]
# Description: Rewrites commit messages with an OpenAI-compatible AI endpoint
# Category: History Rewriting
#
# Rewrites commit messages across all managed repositories using an
# OpenAI-compatible chat completions endpoint. The command scans all commits,
# skips messages that already use Conventional Commits, sends compact redacted
# commit context to the configured API in batches, previews a single global
# summary, and asks once before applying the generated messages with
# git-filter-repo.
#
# Options:
#   --base-url <url>                 (optional) OpenAI-compatible API base URL. Prompts if missing.
#   --model <model>                  (optional) Model name to use. Prompts if missing.
#   --api-key <key>                  (optional) API key for the endpoint. Prompts if missing.
#   --api-key-env <name>             (optional) Environment variable to read for the API key. Defaults to OPENAI_API_KEY.
#   --batch-size <number>            (optional) Commits per API request. Defaults to 10.
#   --max-chars-per-commit <number>  (optional) Per-commit context budget. Defaults to 3000.
#   --timeout <seconds>              (optional) API request timeout. Defaults to 90.
#
# Examples:
#     git-wrangler rewrite-commits-ai --base-url https://api.openai.com/v1 --model gpt-4o-mini
#     git-wrangler rewrite-commits-ai --base-url https://api.deepseek.com --model deepseek-v4-flash --api-key-env DEEPSEEK_API_KEY
# ====

base_url=""
model=""
api_key=""
api_key_env="OPENAI_API_KEY"
batch_size=10
max_chars_per_commit=3000
timeout_seconds=90

config_base_url=""
config_model=""
config_api_key=""
config_api_key_env=""
api_key_source=""
save_api_key=false
prompted_for_nonsecret=false
TTY_PATH=""

CONFIG_DIR="$HOME/.git-wrangler"
CONFIG_FILE="$CONFIG_DIR/config"

print_error() {
    printf "\e[31mError: %s\e[0m\n" "$1" >&2
}

require_value() {
    local option="$1"
    local value="${2:-}"
    if [ -z "$value" ] || [[ "$value" == --* ]]; then
        print_error "$option requires a value."
        exit 1
    fi
}

is_positive_integer() {
    [[ "$1" =~ ^[0-9]+$ ]] && [ "$1" -gt 0 ]
}

require_tty() {
    if [ -r /dev/tty ] && [ -w /dev/tty ]; then
        TTY_PATH="/dev/tty"
        return
    fi

    if [ -t 0 ] && [ -t 1 ]; then
        TTY_PATH=""
        return
    fi

    if [ -z "$TTY_PATH" ]; then
        print_error "rewrite-commits-ai requires an interactive terminal for setup, API consent, and rewrite confirmation."
        exit 1
    fi
}

prompt_write() {
    if [ -n "$TTY_PATH" ]; then
        printf "$@" > "$TTY_PATH"
    else
        printf "$@"
    fi
}

prompt_read() {
    local __target="$1"
    local __value

    if [ -n "$TTY_PATH" ]; then
        IFS= read -r __value < "$TTY_PATH"
    else
        IFS= read -r __value
    fi

    printf -v "$__target" "%s" "$__value"
}

load_config() {
    [ -f "$CONFIG_FILE" ] || return

    local line key value
    while IFS= read -r line; do
        case "$line" in
            ""|\#*) continue ;;
        esac

        key="${line%%=*}"
        value="${line#*=}"

        case "$key" in
            rewrite_commits_ai_base_url) config_base_url="$value" ;;
            rewrite_commits_ai_model) config_model="$value" ;;
            rewrite_commits_ai_api_key) config_api_key="$value" ;;
            rewrite_commits_ai_api_key_env) config_api_key_env="$value" ;;
        esac
    done < "$CONFIG_FILE"
}

save_config() {
    local include_api_key="$1"
    local tmp_config

    mkdir -p "$CONFIG_DIR"
    tmp_config=$(mktemp)

    if [ -f "$CONFIG_FILE" ]; then
        local line key
        while IFS= read -r line; do
            key="${line%%=*}"
            case "$key" in
                rewrite_commits_ai_base_url|rewrite_commits_ai_model|rewrite_commits_ai_api_key|rewrite_commits_ai_api_key_env)
                    continue
                    ;;
            esac
            printf "%s\n" "$line" >> "$tmp_config"
        done < "$CONFIG_FILE"
    fi

    printf "rewrite_commits_ai_base_url=%s\n" "$base_url" >> "$tmp_config"
    printf "rewrite_commits_ai_model=%s\n" "$model" >> "$tmp_config"
    printf "rewrite_commits_ai_api_key_env=%s\n" "$api_key_env" >> "$tmp_config"

    if [ "$include_api_key" = true ] || [ "$api_key_source" = "config" ]; then
        printf "rewrite_commits_ai_api_key=%s\n" "$api_key" >> "$tmp_config"
    fi

    chmod 600 "$tmp_config"
    mv "$tmp_config" "$CONFIG_FILE"
    chmod 600 "$CONFIG_FILE"
}

prompt_value() {
    local label="$1"
    local default_value="$2"
    local answer

    if [ -n "$default_value" ]; then
        prompt_write "%s [%s]: " "$label" "$default_value"
    else
        prompt_write "%s: " "$label"
    fi

    prompt_read answer
    if [ -z "$answer" ]; then
        printf "%s" "$default_value"
    else
        printf "%s" "$answer"
    fi
}

prompt_secret() {
    local label="$1"
    local answer
    local tty_state

    prompt_write "%s: " "$label"
    if [ -n "$TTY_PATH" ]; then
        tty_state=$(stty -g < "$TTY_PATH")
        stty -echo < "$TTY_PATH"
        prompt_read answer
        stty "$tty_state" < "$TTY_PATH"
    else
        tty_state=$(stty -g)
        stty -echo
        prompt_read answer
        stty "$tty_state"
    fi
    prompt_write "\n"

    printf "%s" "$answer"
}

prompt_api_key() {
    local choice

    prompt_write "\e[33mNo API key was found for rewrite-commits-ai.\e[0m\n"
    prompt_write "Choose how to continue:\n"
    prompt_write "  1) Stop so I can configure it manually\n"
    prompt_write "  2) Enter an API key for this run only\n"
    prompt_write "  3) Enter an API key and save it for future runs\n"
    prompt_write "Selection [1-3]: "
    prompt_read choice

    case "$choice" in
        1)
            printf "\e[33mStopped before sending any data. Set --api-key, --api-key-env, or save a key in %s.\e[0m\n" "$CONFIG_FILE"
            exit 0
            ;;
        2)
            api_key=$(prompt_secret "API key for this run")
            api_key_source="prompt"
            ;;
        3)
            prompt_write "\e[33mThe API key will be stored as plaintext in %s with file mode 600.\e[0m\n" "$CONFIG_FILE"
            prompt_write "Save the key anyway? [y/N] "
            prompt_read confirm_save
            if [ "$confirm_save" != "y" ] && [ "$confirm_save" != "Y" ]; then
                prompt_write "\e[33mKey was not saved. Enter it for this run instead.\e[0m\n"
                api_key=$(prompt_secret "API key for this run")
                api_key_source="prompt"
            else
                api_key=$(prompt_secret "API key to save")
                api_key_source="prompt"
                save_api_key=true
            fi
            ;;
        *)
            print_error "Invalid selection."
            exit 1
            ;;
    esac

    if [ -z "$api_key" ]; then
        print_error "API key cannot be empty."
        exit 1
    fi
}

maybe_save_nonsecret_config() {
    if [ "$save_api_key" = true ]; then
        save_config true
        printf "\e[32mSaved rewrite-commits-ai settings to %s\e[0m\n" "$CONFIG_FILE"
        return
    fi

    if [ "$prompted_for_nonsecret" = true ]; then
        local answer
        prompt_write "Save base URL, model, and API key env name to %s for future runs? [y/N] " "$CONFIG_FILE"
        prompt_read answer
        if [ "$answer" = "y" ] || [ "$answer" = "Y" ]; then
            save_config false
            printf "\e[32mSaved rewrite-commits-ai settings to %s\e[0m\n" "$CONFIG_FILE"
        fi
    fi
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --base-url)
            require_value "$1" "${2:-}"
            base_url="$2"
            shift 2
            ;;
        --model)
            require_value "$1" "${2:-}"
            model="$2"
            shift 2
            ;;
        --api-key)
            require_value "$1" "${2:-}"
            api_key="$2"
            api_key_source="arg"
            shift 2
            ;;
        --api-key-env)
            require_value "$1" "${2:-}"
            api_key_env="$2"
            shift 2
            ;;
        --batch-size)
            require_value "$1" "${2:-}"
            batch_size="$2"
            shift 2
            ;;
        --max-chars-per-commit)
            require_value "$1" "${2:-}"
            max_chars_per_commit="$2"
            shift 2
            ;;
        --timeout)
            require_value "$1" "${2:-}"
            timeout_seconds="$2"
            shift 2
            ;;
        *)
            printf "\e[31mUnknown option: %s\e[0m\n" "$1" >&2
            exit 1
            ;;
    esac
done

if ! is_positive_integer "$batch_size"; then
    print_error "--batch-size must be a positive integer."
    exit 1
fi

if [ "$batch_size" -gt 50 ]; then
    print_error "--batch-size must be 50 or less."
    exit 1
fi

if ! is_positive_integer "$max_chars_per_commit"; then
    print_error "--max-chars-per-commit must be a positive integer."
    exit 1
fi

if ! is_positive_integer "$timeout_seconds"; then
    print_error "--timeout must be a positive integer."
    exit 1
fi

if ! command -v git &> /dev/null; then
    print_error "'git' is not installed. Please install it first."
    exit 1
fi

if ! command -v git-filter-repo &> /dev/null; then
    print_error "'git filter-repo' is not installed. Please install it first."
    exit 1
fi

if command -v python3 &> /dev/null; then
    python_cmd="python3"
else
    print_error "'python3' is not installed. Please install it first."
    exit 1
fi

require_tty
load_config

if [ -z "$base_url" ] && [ -n "$config_base_url" ]; then
    base_url="$config_base_url"
fi

if [ -z "$model" ] && [ -n "$config_model" ]; then
    model="$config_model"
fi

if [ "$api_key_env" = "OPENAI_API_KEY" ] && [ -n "$config_api_key_env" ]; then
    api_key_env="$config_api_key_env"
fi

if [ -z "$api_key" ] && [ -n "$config_api_key" ]; then
    api_key="$config_api_key"
    api_key_source="config"
fi

if [ -z "$api_key" ] && [ -n "$api_key_env" ]; then
    api_key="${!api_key_env:-}"
    if [ -n "$api_key" ]; then
        api_key_source="env"
    fi
fi

if [ -z "$base_url" ]; then
    base_url=$(prompt_value "OpenAI-compatible base URL" "https://api.openai.com/v1")
    prompted_for_nonsecret=true
fi

if [ -z "$model" ]; then
    model=$(prompt_value "Model" "")
    prompted_for_nonsecret=true
fi

if [ -z "$model" ]; then
    print_error "Model cannot be empty."
    exit 1
fi

if [ -z "$api_key" ]; then
    prompt_api_key
fi

maybe_save_nonsecret_config

git_repositories=$(find . -maxdepth 2 -type d -name '.git')

if [ -z "$git_repositories" ]; then
    printf "\e[33mNo Git repositories found in the specified directory.\e[0m\n"
    exit 0
fi

work_dir=$(mktemp -d)
cleanup() {
    rm -rf "$work_dir"
}
trap cleanup EXIT

repos_file="$work_dir/repos.txt"
manifest_file="$work_dir/manifest.tsv"
summary_file="$work_dir/summary.txt"
generator_script="$work_dir/generate.py"

printf "%s\n" "$git_repositories" > "$repos_file"

cat > "$generator_script" <<'PYEOF'
import json
import os
import re
import subprocess
import sys
import time
import urllib.error
import urllib.request

RED = "\033[31m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
CYAN = "\033[36m"
RESET = "\033[0m"

CONVENTIONAL_RE = re.compile(
    r"^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\([^)]+\))?!?: .+"
)

SECRET_PATTERNS = [
    re.compile(r"(['\"]?)(sk-[a-zA-Z0-9_-]{20,}|sk_[a-zA-Z0-9_-]{20,})(['\"]?)"),
    re.compile(r"(['\"]?)(gh[pousr]_[a-zA-Z0-9_]{20,})(['\"]?)"),
    re.compile(r"(['\"]?)(xox[pboa]-[a-zA-Z0-9-]{10,})(['\"]?)"),
    re.compile(r"\bAKIA[0-9A-Z]{16}\b"),
    re.compile(r"(['\"]?)(sk_live_[a-zA-Z0-9]{16,}|pk_live_[a-zA-Z0-9]{16,}|sk_test_[a-zA-Z0-9]{16,}|pk_test_[a-zA-Z0-9]{16,})(['\"]?)"),
    re.compile(r"-----BEGIN (RSA |DSA |EC |OPENSSH )?PRIVATE KEY-----[\s\S]*?-----END (RSA |DSA |EC |OPENSSH )?PRIVATE KEY-----"),
    re.compile(r"(['\"]?)(eyJ[a-zA-Z0-9_-]+\.eyJ[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+)(['\"]?)"),
    re.compile(r"(password|passwd|pwd|secret|api_key|apikey|auth_token|access_token|private_key)\s*[:=]\s*['\"][^'\"]{8,}['\"]", re.I),
    re.compile(r"(mongodb(\+srv)?|postgres(ql)?|mysql|redis)://[^@\s]+@[^\s]+", re.I),
    re.compile(r"Bearer\s+[a-zA-Z0-9_.-]+", re.I),
]


def fail(message):
    print(f"{RED}Error: {message}{RESET}", file=sys.stderr)
    sys.exit(1)


def run_git(repo_dir, args, check=True):
    proc = subprocess.run(
        ["git"] + args,
        cwd=repo_dir,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    if check and proc.returncode != 0:
        raise RuntimeError(proc.stderr.strip() or proc.stdout.strip() or "git command failed")
    return proc.stdout


def ask_yes_no(question):
    try:
        with open("/dev/tty", "r+", encoding="utf-8") as tty:
            tty.write(question)
            tty.flush()
            answer = tty.readline().strip().lower()
    except OSError:
        if not sys.stdin.isatty():
            fail("interactive terminal is required.")
        sys.stdout.write(question)
        sys.stdout.flush()
        answer = sys.stdin.readline().strip().lower()

    return answer in ("y", "yes")


def repo_display_name(repo_dir, root_dir):
    rel = os.path.relpath(repo_dir, root_dir)
    if rel == ".":
        return os.path.basename(root_dir)
    return os.path.basename(repo_dir)


def is_conventional(message):
    first_line = message.strip().splitlines()[0] if message.strip() else ""
    return bool(CONVENTIONAL_RE.match(first_line))


def is_sensitive_path(path):
    normalized = path.replace("\\", "/").lower()
    base = normalized.rsplit("/", 1)[-1]
    if base == ".env" or base.startswith(".env."):
        return True
    if base in {
        "id_rsa",
        "id_rsa.pub",
        "id_ed25519",
        "id_ed25519.pub",
        "credentials.json",
        "secrets.json",
    }:
        return True
    if base.endswith((".pem", ".key", ".p12", ".pfx")):
        return True
    if ("secret" in normalized or "credential" in normalized) and base.endswith(
        (".json", ".yml", ".yaml", ".toml", ".ini", ".env")
    ):
        return True
    return False


def redact_line(line):
    redacted = line
    for pattern in SECRET_PATTERNS:
        redacted = pattern.sub("[REDACTED]", redacted)
    return redacted


def diff_path(line):
    match = re.match(r"diff --git a/(.*?) b/(.*)$", line)
    if match:
        return match.group(2)
    return ""


def redact_diff(diff_text):
    redacted_lines = []
    hiding_file = False

    for line in diff_text.splitlines():
        if line.startswith("diff --git "):
            path = diff_path(line)
            hiding_file = is_sensitive_path(path)
            redacted_lines.append(redact_line(line))
            if hiding_file:
                redacted_lines.append("[SENSITIVE FILE CONTENT HIDDEN]")
            continue

        if hiding_file:
            continue

        redacted_lines.append(redact_line(line))

    return "\n".join(redacted_lines)


def truncate_text(text, limit):
    if len(text) <= limit:
        return text
    suffix = "\n[TRUNCATED TO PER-COMMIT CONTEXT BUDGET]"
    return text[: max(0, limit - len(suffix))] + suffix


def limited_lines(text, max_lines):
    lines = [line for line in text.splitlines() if line.strip()]
    if len(lines) <= max_lines:
        return "\n".join(lines)
    return "\n".join(lines[:max_lines] + [f"[TRUNCATED {len(lines) - max_lines} LINES]"])


def build_context(repo_dir, repo_name, commit_hash, char_budget):
    name_status = run_git(
        repo_dir,
        ["diff-tree", "--root", "--no-commit-id", "--name-status", "-r", commit_hash],
    )
    numstat = run_git(
        repo_dir,
        ["diff-tree", "--root", "--no-commit-id", "--numstat", "-r", commit_hash],
    )

    if not name_status.strip() and not numstat.strip():
        return ""

    diff_text = run_git(
        repo_dir,
        [
            "show",
            "--format=",
            "--no-color",
            "--no-ext-diff",
            "--find-renames",
            "--find-copies",
            "--unified=3",
            commit_hash,
        ],
    )
    diff_text = redact_diff(diff_text)

    context = "\n".join(
        [
            f"Repository: {repo_name}",
            f"Commit: {commit_hash[:12]}",
            "",
            "Files changed:",
            limited_lines(name_status, 80),
            "",
            "Stats:",
            limited_lines(numstat, 80),
            "",
            "Redacted diff snippet:",
            diff_text,
        ]
    )

    return truncate_text(context, char_budget)


def collect_items(repos_file, char_budget):
    root_dir = os.getcwd()
    items = []
    repo_count = 0
    skipped_formatted = 0
    skipped_empty = 0
    skipped_unborn = 0

    with open(repos_file, "r", encoding="utf-8") as f:
        git_dirs = [line.strip() for line in f if line.strip()]

    for repo_index, git_dir in enumerate(git_dirs):
        repo_dir = os.path.abspath(os.path.dirname(git_dir))
        repo_name = repo_display_name(repo_dir, root_dir)
        repo_count += 1

        try:
            run_git(repo_dir, ["rev-parse", "HEAD"])
        except RuntimeError:
            skipped_unborn += 1
            continue

        try:
            commits_output = run_git(repo_dir, ["rev-list", "--reverse", "--all"])
        except RuntimeError as exc:
            print(f"{YELLOW}Skipping {repo_name}: {exc}{RESET}")
            continue

        commits = [line.strip() for line in commits_output.splitlines() if line.strip()]

        for commit_hash in commits:
            old_message = run_git(repo_dir, ["log", "-1", "--format=%B", commit_hash]).strip()
            if is_conventional(old_message):
                skipped_formatted += 1
                continue

            try:
                context = build_context(repo_dir, repo_name, commit_hash, char_budget)
            except RuntimeError as exc:
                print(f"{YELLOW}Skipping {repo_name} {commit_hash[:8]}: {exc}{RESET}")
                skipped_empty += 1
                continue

            if not context.strip():
                skipped_empty += 1
                continue

            item_id = f"c{len(items) + 1:06d}"
            items.append(
                {
                    "id": item_id,
                    "repo_index": repo_index,
                    "repo_dir": repo_dir,
                    "repo_name": repo_name,
                    "hash": commit_hash,
                    "old_message": old_message,
                    "context": context,
                }
            )

    return items, {
        "repo_count": repo_count,
        "skipped_formatted": skipped_formatted,
        "skipped_empty": skipped_empty,
        "skipped_unborn": skipped_unborn,
    }


def chat_endpoint(base_url):
    base = base_url.rstrip("/")
    if base.endswith("/chat/completions"):
        return base
    return base + "/chat/completions"


def parse_json_response(content):
    text = content.strip()
    if text.startswith("```"):
        text = re.sub(r"^```(?:json)?\s*", "", text)
        text = re.sub(r"\s*```$", "", text)

    try:
        return json.loads(text)
    except json.JSONDecodeError:
        start = text.find("{")
        end = text.rfind("}")
        if start != -1 and end != -1 and end > start:
            return json.loads(text[start : end + 1])
        raise


def normalize_message(message):
    if not isinstance(message, str):
        return ""
    lines = [line.strip() for line in message.strip().strip('"').strip("'").splitlines() if line.strip()]
    if not lines:
        return ""
    return lines[0]


def validate_message(message):
    if not message:
        return False
    if len(message) > 120:
        return False
    return bool(CONVENTIONAL_RE.match(message))


def extract_messages(data):
    if isinstance(data, dict) and isinstance(data.get("messages"), list):
        rows = data["messages"]
    elif isinstance(data, list):
        rows = data
    elif isinstance(data, dict):
        rows = [{"id": key, "message": value} for key, value in data.items()]
    else:
        rows = []

    result = {}
    for row in rows:
        if not isinstance(row, dict):
            continue
        item_id = str(row.get("id", "")).strip()
        message = normalize_message(row.get("message", ""))
        if item_id:
            result[item_id] = message
    return result


def request_batch(batch, base_url, model, api_key, timeout_seconds):
    endpoint = chat_endpoint(base_url)
    commits = [
        {
            "id": item["id"],
            "repository": item["repo_name"],
            "commit": item["hash"][:12],
            "context": item["context"],
        }
        for item in batch
    ]

    system_prompt = (
        "You generate concise Conventional Commit messages. "
        "Return valid JSON only. Do not include Markdown or explanations."
    )
    user_prompt = (
        "Generate one Conventional Commit message for each commit below.\n"
        "Use only the changed files, stats, and redacted diff snippets. "
        "Old commit messages are intentionally not provided.\n"
        "Rules:\n"
        "- Return exactly this JSON shape: {\"messages\":[{\"id\":\"c000001\",\"message\":\"feat(scope): add thing\"}]}\n"
        "- Preserve every input id exactly once.\n"
        "- Use types: feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert.\n"
        "- Use lowercase messages, present tense, no trailing period.\n"
        "- Keep each first line under 72 characters when possible and always under 120 characters.\n\n"
        f"Commits:\n{json.dumps(commits, ensure_ascii=False)}"
    )

    payload = {
        "model": model,
        "messages": [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": user_prompt},
        ],
        "temperature": 0.2,
        "max_tokens": min(max(400, len(batch) * 160), 4000),
    }

    request = urllib.request.Request(
        endpoint,
        data=json.dumps(payload).encode("utf-8"),
        headers={
            "Authorization": f"Bearer {api_key}",
            "Content-Type": "application/json",
        },
        method="POST",
    )

    try:
        with urllib.request.urlopen(request, timeout=timeout_seconds) as response:
            body = response.read().decode("utf-8")
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace")
        raise RuntimeError(f"HTTP {exc.code}: {body[:500]}")
    except urllib.error.URLError as exc:
        raise RuntimeError(str(exc.reason))

    try:
        data = json.loads(body)
        content = data["choices"][0]["message"]["content"]
    except (KeyError, IndexError, TypeError, json.JSONDecodeError) as exc:
        raise RuntimeError(f"unexpected API response: {exc}")

    parsed = parse_json_response(content)
    return extract_messages(parsed)


def process_batch(batch, base_url, model, api_key, timeout_seconds):
    accepted = {}
    pending = list(batch)
    errors = {}

    for attempt in range(1, 4):
        if not pending:
            break

        try:
            returned = request_batch(pending, base_url, model, api_key, timeout_seconds)
            next_pending = []
            for item in pending:
                message = returned.get(item["id"], "")
                if validate_message(message):
                    accepted[item["id"]] = message
                else:
                    errors[item["id"]] = "missing or invalid message"
                    next_pending.append(item)
            pending = next_pending
        except Exception as exc:
            errors = {item["id"]: str(exc) for item in pending}

        if pending and attempt < 3:
            print(f"{YELLOW}Retrying {len(pending)} commit(s) after failed batch attempt {attempt}.{RESET}")
            time.sleep(2 * attempt)

    failures = [{"item": item, "reason": errors.get(item["id"], "unknown error")} for item in pending]
    return accepted, failures


def process_items(items, base_url, model, api_key, batch_size, timeout_seconds):
    results = {}
    failures = []
    total_batches = (len(items) + batch_size - 1) // batch_size

    for batch_index, start in enumerate(range(0, len(items), batch_size), start=1):
        batch = items[start : start + batch_size]
        print(f"{CYAN}Generating batch {batch_index}/{total_batches} ({len(batch)} commit(s))...{RESET}")
        accepted, batch_failures = process_batch(batch, base_url, model, api_key, timeout_seconds)
        results.update(accepted)
        failures.extend(batch_failures)

    return results, failures


def write_outputs(items, results, stats, manifest_file, summary_file, output_dir):
    changed_by_repo = {}
    changed_samples = []
    unchanged_generated = 0

    for item in items:
        message = results.get(item["id"])
        if not message:
            continue

        if message == item["old_message"].strip():
            unchanged_generated += 1
            continue

        key = (item["repo_index"], item["repo_dir"], item["repo_name"])
        changed_by_repo.setdefault(key, []).append((item["hash"], message))
        if len(changed_samples) < 12:
            changed_samples.append((item["repo_name"], item["hash"][:8], message))

    manifest_lines = []
    for (repo_index, repo_dir, repo_name), mappings in sorted(changed_by_repo.items()):
        callback_file = os.path.join(output_dir, f"callback-{repo_index}.py")
        with open(callback_file, "w", encoding="utf-8") as f:
            f.write("mapping = {}\n")
            for commit_hash, message in mappings:
                f.write(f"mapping[{commit_hash.encode('utf-8')!r}] = {(message + chr(10)).encode('utf-8')!r}\n")
            f.write("if commit.original_id in mapping:\n")
            f.write("    commit.message = mapping[commit.original_id]\n")
        manifest_lines.append(f"{repo_dir}\t{repo_name}\t{callback_file}\t{len(mappings)}")

    with open(manifest_file, "w", encoding="utf-8") as f:
        if manifest_lines:
            f.write("\n".join(manifest_lines) + "\n")

    changed_count = sum(len(mappings) for mappings in changed_by_repo.values())
    summary = [
        "",
        "AI commit rewrite summary",
        "-------------------------",
        f"Repositories scanned: {stats['repo_count']}",
        f"Repositories with generated rewrites: {len(changed_by_repo)}",
        f"Commits sent to API: {len(items)}",
        f"Generated rewrites: {changed_count}",
        f"Generated but unchanged: {unchanged_generated}",
        f"Skipped already Conventional Commits: {stats['skipped_formatted']}",
        f"Skipped empty/unreadable commits: {stats['skipped_empty']}",
    ]

    if stats["skipped_unborn"] > 0:
        summary.append(f"Skipped repositories with no commits: {stats['skipped_unborn']}")

    if changed_samples:
        summary.extend(["", "Sample generated messages:"])
        for repo_name, short_hash, message in changed_samples:
            summary.append(f"  {repo_name} {short_hash}: {message}")

    if changed_count == 0:
        summary.extend(["", "No generated messages require rewriting."])

    with open(summary_file, "w", encoding="utf-8") as f:
        f.write("\n".join(summary) + "\n")


def main():
    base_url = os.environ["AI_BASE_URL"]
    model = os.environ["AI_MODEL"]
    api_key = os.environ["AI_API_KEY"]
    repos_file = os.environ["AI_REPOS_FILE"]
    manifest_file = os.environ["AI_MANIFEST_FILE"]
    summary_file = os.environ["AI_SUMMARY_FILE"]
    output_dir = os.environ["AI_OUTPUT_DIR"]
    batch_size = int(os.environ["AI_BATCH_SIZE"])
    char_budget = int(os.environ["AI_MAX_CHARS_PER_COMMIT"])
    timeout_seconds = int(os.environ["AI_TIMEOUT_SECONDS"])

    print(f"{CYAN}Scanning repositories and preparing redacted commit context...{RESET}")
    items, stats = collect_items(repos_file, char_budget)

    if not items:
        with open(manifest_file, "w", encoding="utf-8"):
            pass
        with open(summary_file, "w", encoding="utf-8") as f:
            f.write("No commits require AI rewriting. Existing Conventional Commit messages were skipped.\n")
        return

    batches = (len(items) + batch_size - 1) // batch_size
    print("")
    print(f"{YELLOW}Data send notice{RESET}")
    print(f"Endpoint: {base_url}")
    print(f"Model: {model}")
    print(f"Repositories scanned: {stats['repo_count']}")
    print(f"Commits to send: {len(items)}")
    print(f"API batches: {batches}")
    print(f"Per-commit context budget: {char_budget} characters")
    print("The command will send file paths, stats, and redacted diff snippets.")
    print("Old commit messages and API keys are not sent in commit context.")

    if not ask_yes_no("Send this data to the configured API endpoint? [y/N] "):
        print(f"{YELLOW}Stopped before sending any data.{RESET}")
        with open(manifest_file, "w", encoding="utf-8"):
            pass
        with open(summary_file, "w", encoding="utf-8") as f:
            f.write("Operation cancelled before any API requests were made.\n")
        return

    results, failures = process_items(items, base_url, model, api_key, batch_size, timeout_seconds)

    while failures:
        print(f"{YELLOW}{len(failures)} commit(s) failed after automatic retries.{RESET}")
        if not ask_yes_no("Retry only failed commits now? [y/N] "):
            fail("AI generation is incomplete. No history was changed.")
        retry_items = [failure["item"] for failure in failures]
        retry_results, failures = process_items(
            retry_items,
            base_url,
            model,
            api_key,
            batch_size,
            timeout_seconds,
        )
        results.update(retry_results)

    write_outputs(items, results, stats, manifest_file, summary_file, output_dir)


if __name__ == "__main__":
    main()
PYEOF

if ! AI_BASE_URL="$base_url" \
    AI_MODEL="$model" \
    AI_API_KEY="$api_key" \
    AI_REPOS_FILE="$repos_file" \
    AI_MANIFEST_FILE="$manifest_file" \
    AI_SUMMARY_FILE="$summary_file" \
    AI_OUTPUT_DIR="$work_dir" \
    AI_BATCH_SIZE="$batch_size" \
    AI_MAX_CHARS_PER_COMMIT="$max_chars_per_commit" \
    AI_TIMEOUT_SECONDS="$timeout_seconds" \
    "$python_cmd" "$generator_script"; then
    exit 1
fi

if [ -f "$summary_file" ]; then
    cat "$summary_file"
fi

if [ ! -s "$manifest_file" ]; then
    exit 0
fi

printf "\e[31mWARNING: This operation rewrites Git history. A force push will be required to update remotes.\e[0m\n" >&2
prompt_write "Apply these generated commit messages to all listed repositories? [y/N] "
prompt_read apply_answer

if [ "$apply_answer" != "y" ] && [ "$apply_answer" != "Y" ]; then
    printf "\e[33mRewrite cancelled. Generated AI messages were temporary and have been discarded.\e[0m\n"
    exit 0
fi

had_error=false

while IFS= read -r manifest_line; do
    [ -n "$manifest_line" ] || continue

    IFS=$'\t' read -r repo_dir repo_name_display callback_file changed_count <<< "$manifest_line"

    if (
        cd "$repo_dir" || exit 1
        remote_url=$(git remote get-url origin 2>/dev/null)

        if filter_output=$(git filter-repo --partial --commit-callback "$callback_file" --force 2>&1); then
            if [ -n "$remote_url" ] && ! git remote get-url origin >/dev/null 2>&1; then
                if ! restore_output=$(git remote add origin "$remote_url" 2>&1); then
                    printf "\e[31mWarning: Commit rewrite completed for %s, but origin could not be restored:\n%s\e[0m\n\n" "$repo_name_display" "$restore_output" >&2
                    exit 1
                fi
            fi

            printf "\e[32mRewrote %s commit message(s) for %s\e[0m\n" "$changed_count" "$repo_name_display"
        else
            printf "\e[31mError: Could not rewrite commit messages for %s:\n%s\e[0m\n\n" "$repo_name_display" "$filter_output" >&2
            exit 1
        fi
    ); then
        :
    else
        had_error=true
    fi
done < "$manifest_file"

if [ "$had_error" = true ]; then
    exit 1
fi
