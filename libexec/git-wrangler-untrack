#!/bin/bash

# ====
# Usage: git-wrangler untrack
# Description: Removes tracked files that match .gitignore exclusion rules
# Category: Local Operations
#
# Removes files from the Git index that are actively tracked but match
# exclusion rules in .gitignore. It untracks the files safely while leaving
# them on the local disk, and commits the removals automatically.
#
# This command takes no arguments.
#
# Example:
#     git-wrangler untrack
# ====

UI_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
# shellcheck source=libexec/git-wrangler-ui
source "$UI_DIR/git-wrangler-ui"
# shellcheck source=libexec/git-wrangler-core
source "$UI_DIR/git-wrangler-core"


# Parse command-line arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        *)
            gw_error "Unknown option: $1"
            exit 1
            ;;
    esac
done

gw_require_git "untrack"

# Find target repositories
git_repositories=$(gw_find_git_repositories)

if [ -z "$git_repositories" ]; then
    gw_warn "No Git repositories found in the specified directory."
    exit 0
fi

# Iterate through each repository
while IFS= read -r git_dir; do
    (
        # Get repository directory and name
        repo_dir=$(gw_repo_dir_from_git_dir "$git_dir")
        repo_name_display=$(gw_repo_display_name "$repo_dir")

        cd "$repo_dir" || exit

        # Stop tracking files that match .gitignore patterns
        if [ -f ".gitignore" ]; then
            # Identify tracked files matching ignore patterns
            if [ -n "$(git ls-files --ignored --cached --exclude-standard)" ]; then
                # Untrack and commit ignored files
                if error_message=$(git ls-files --ignored --cached --exclude-standard -z | xargs -0 git rm --cached -q -- 2>&1); then
                    if commit_output=$(git commit -q -m "Stop tracking files defined in .gitignore" 2>&1); then
                        printf "${GW_GREEN}Stopped tracking and committed ignored files for %s${GW_RESET}\n" "$repo_name_display"
                    else
                        printf "${GW_RED}Error: Could not commit changes for %s:\n%s${GW_RESET}\n\n" "$repo_name_display" "$commit_output" >&2
                    fi
                else
                    printf "${GW_RED}Error: Could not untrack files for %s:\n%s${GW_RESET}\n\n" "$repo_name_display" "$error_message" >&2
                fi
            else
                printf "${GW_YELLOW}No currently tracked files match .gitignore in %s. Skipping...${GW_RESET}\n" "$repo_name_display"
            fi
        else
            printf "${GW_YELLOW}No .gitignore file found for %s. Skipping...${GW_RESET}\n" "$repo_name_display"
        fi
    )
done <<< "$git_repositories"
