#!/bin/bash

# ====
# Usage: git-wrangler update [--confirm]
# Description: Updates Git Wrangler to the latest version
# Category: Utility
#
# Checks if a newer version of Git Wrangler is available on GitHub by
# comparing the local commit against the remote. If an update is available,
# prompts for confirmation before applying it unless --confirm is supplied.
#
# Options:
#   --confirm  (optional) Skip the interactive confirmation prompt.
#
# Examples:
#     git-wrangler update
#     git-wrangler update --confirm
# ====

UI_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
# shellcheck source=libexec/git-wrangler-ui
source "$UI_DIR/git-wrangler-ui"
# shellcheck source=libexec/git-wrangler-core
source "$UI_DIR/git-wrangler-core"


confirm=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --confirm)
            confirm=true
            shift
            ;;
        *)
            gw_error "Unknown option: $1"
            exit 1
            ;;
    esac
done

gw_require_git "update"

# ── Resolve the git-wrangler installation directory ──────────────────────────────
# This script lives in libexec/, so the install root is one level up.

INSTALL_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." && pwd )"

if [ ! -d "$INSTALL_DIR/.git" ]; then
    printf "${GW_RED}Error: %s is not a git repository. Cannot check for updates.${GW_RESET}\n" "$INSTALL_DIR" >&2
    exit 1
fi

# ── Determine the current branch ────────────────────────────────────────────

branch=$(git -C "$INSTALL_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null)

if [ -z "$branch" ] || [ "$branch" = "HEAD" ]; then
    printf "${GW_RED}Error: Could not determine the current branch.${GW_RESET}\n" >&2
    exit 1
fi

# ── Compare local vs remote ─────────────────────────────────────────────────

printf "${GW_BOLD}${GW_CYAN}${GW_STEP_SYMBOL}${GW_RESET} Checking for updates on %s...\n" "$branch"

local_sha=$(git -C "$INSTALL_DIR" rev-parse HEAD 2>/dev/null)

remote_sha=$(git -C "$INSTALL_DIR" ls-remote origin "refs/heads/$branch" 2>/dev/null | cut -f1)

if [ -z "$remote_sha" ]; then
    printf "${GW_RED}Error: Could not reach the remote repository. Check your network connection.${GW_RESET}\n" >&2
    exit 1
fi

if [ "$local_sha" = "$remote_sha" ]; then
    printf "${GW_GREEN}${GW_OK_SYMBOL} Git Wrangler is already up to date.${GW_RESET}\n"
    exit 0
fi

# ── Update available ─────────────────────────────────────────────────────────

printf "\n"
printf "${GW_YELLOW}${GW_WARN_SYMBOL} A newer version is available.${GW_RESET}\n"
printf "\n"
printf "  Local:  %s\n" "${local_sha:0:12}"
printf "  Remote: %s\n" "${remote_sha:0:12}"
printf "\n"

if [ "$confirm" != true ]; then
    if ! gw_confirm "Update Git Wrangler?"; then
        printf "${GW_YELLOW}Aborted.${GW_RESET}\n"
        exit 0
    fi
    printf "\n"
fi

# ── Apply update ─────────────────────────────────────────────────────────────

printf "${GW_BOLD}${GW_CYAN}${GW_STEP_SYMBOL}${GW_RESET} Updating...\n"

if update_output=$(git -C "$INSTALL_DIR" fetch origin "$branch" 2>&1) && \
   update_output=$(git -C "$INSTALL_DIR" reset --hard "origin/$branch" 2>&1); then
    # Ensure scripts are executable after update
    chmod +x "$INSTALL_DIR/git-wrangler" 2>/dev/null || true
    chmod +x "$INSTALL_DIR"/libexec/git-wrangler-* 2>/dev/null || true

    printf "${GW_GREEN}${GW_OK_SYMBOL} Git Wrangler updated successfully.${GW_RESET}\n"
else
    printf "${GW_RED}Error: Update failed:\n%s${GW_RESET}\n" "$update_output" >&2
    exit 1
fi
