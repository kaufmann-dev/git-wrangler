#!/bin/bash

# ====
# Usage: wrangler status
# Description: Shows dirty/clean and ahead/behind status of tracked repositories
# Category: Utility
#
# Iterates through Git repositories found in the current directory and its
# immediate subdirectories and displays a unified dashboard of their real-time
# sync state, dirty/clean working tree status, and commit metrics.
#
# This command takes no arguments.
#
# Example:
#     wrangler status
# ====

# Parse command-line arguments
while [[ $# -gt 0 ]]; do
  case "$1" in
    *)
      printf "\e[31mUnknown option: %s\e[0m\n" "$1"
      exit 1
      ;;
  esac
done

# Check prerequisites
if ! command -v git &> /dev/null; then
    printf "\e[31mError: 'git' is not installed. Please install it first.\e[0m\n"
    exit 1
fi

# Find target repositories
git_repositories=$(find . -maxdepth 2 -type d -name '.git')

if [ -z "$git_repositories" ]; then
    printf "\e[33mNo Git repositories found in the specified directory.\e[0m\n"
    exit 0
fi

# Setup metrics file
tmp_counts=$(mktemp)
# Ensure the file is deleted on exit
trap 'rm -f "$tmp_counts"' EXIT

# Print table header
printf "%-30s | %-5s | %s\n" "REPOSITORY" "STATE" "TRACKING"
printf "%s\n" "-------------------------------+-------+------------------------"

# Iterate through each repository
while IFS= read -r git_dir; do
    (
        # Get repository path and display name
        repo_path=$(dirname "$git_dir")

        if [ "$repo_path" = "." ]; then
            repo_name_display="${PWD##*/}"
        else
            repo_name_display=$(basename "$repo_path")
        fi

        if [ "${#repo_name_display}" -gt 30 ]; then
            repo_name_display="${repo_name_display:0:27}..."
        fi

        cd "$repo_path" || exit

        # 1. Dirty/Clean Status
        is_dirty=0
        if [ -n "$(git status --porcelain 2>/dev/null)" ]; then
            dirty_col="\e[33mdirty\e[0m"
            is_dirty=1
        else
            dirty_col="\e[32mclean\e[0m"
        fi

        # 2. Ahead/Behind Status
        status_output=$(git status --porcelain=v2 --branch 2>/dev/null)
        ab_line=$(printf "%s\n" "$status_output" | grep "^# branch.ab ")
        upstream_line=$(printf "%s\n" "$status_output" | grep "^# branch.upstream ")

        is_behind=0
        has_no_remote=0

        if [ -z "$upstream_line" ]; then
            ab_label="\e[90mno remote\e[0m"
            has_no_remote=1
        else
            if [ -n "$ab_line" ]; then
                ahead_count=$(printf "%s\n" "$ab_line" | awk '{print $3}' | tr -d '+')
                behind_count=$(printf "%s\n" "$ab_line" | awk '{print $4}' | tr -d '-')
                
                if [ "$ahead_count" -gt 0 ] && [ "$behind_count" -gt 0 ]; then
                    ab_label="\e[36mahead ${ahead_count}\e[0m, \e[31mbehind ${behind_count}\e[0m"
                    is_behind=1
                elif [ "$ahead_count" -gt 0 ]; then
                    ab_label="\e[36mahead ${ahead_count}\e[0m"
                elif [ "$behind_count" -gt 0 ]; then
                    ab_label="\e[31mbehind ${behind_count}\e[0m"
                    is_behind=1
                else
                    ab_label="up to date"
                fi
            else
                ab_label="up to date"
            fi
        fi

        # Print the row
        printf "%-30s | %b | %b\n" "$repo_name_display" "$dirty_col" "$ab_label"

        # Record metrics
        printf "%d %d %d\n" "$is_dirty" "$is_behind" "$has_no_remote" >> "$tmp_counts"

    )
done <<< "$git_repositories"

# Print summary
printf "%s\n" "-------------------------------+-------+------------------------"

total_dirty=0
total_behind=0
total_no_remote=0

while read -r is_dirty is_behind has_no_remote; do
    if [ -n "$is_dirty" ]; then
        ((total_dirty += is_dirty))
        ((total_behind += is_behind))
        ((total_no_remote += has_no_remote))
    fi
done < "$tmp_counts"

printf "Summary: \e[33m%d dirty\e[0m, \e[31m%d behind\e[0m, \e[90m%d no remote\e[0m\n" "$total_dirty" "$total_behind" "$total_no_remote"
