#!/bin/bash

# ====
# Usage: git-wrangler commit --message <commit_message>
# Description: Stages all changes and creates a commit across multiple repositories
# Category: Local Operations
#
# Iterates through Git repositories found in the current directory and its
# immediate subdirectories, stages all changes (git add -A), and creates a
# commit with the provided message. Repositories with no staged changes are
# skipped automatically.
#
# Options:
#   --message <commit_message>  (required) The commit message to use for all repositories.
#
# Example:
#     git-wrangler commit --message "chore: update dependencies"
# ====

UI_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
# shellcheck source=libexec/git-wrangler-ui
source "$UI_DIR/git-wrangler-ui"


message=""

# Parse command-line arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --message)
            message="$2"
            shift 2
            ;;
        *)
            gw_error "Unknown option: $1"
            exit 1
            ;;
    esac
done

# Validate required arguments
if [ -z "$message" ]; then
    printf "${GW_RED}Error: A commit message is required. Use --message <commit_message>.${GW_RESET}\n" >&2
    exit 1
fi

# Check prerequisites
if ! command -v git &> /dev/null; then
    printf "${GW_RED}Error: 'git' is required for commit. Run 'git-wrangler doctor' for more information.${GW_RESET}\n" >&2
    exit 1
fi

# Find target repositories
git_repositories=$(find . -maxdepth 2 -type d -name '.git')

if [ -z "$git_repositories" ]; then
    gw_warn "No Git repositories found in the specified directory."
    exit 0
fi

# Iterate through each repository
while IFS= read -r git_dir; do
    (
        # Get repository path and display name
        repo_path=$(dirname "$git_dir")

        if [ "$repo_path" = "." ]; then
            repo_name_display="${PWD##*/}"
        else
            repo_name_display=$(basename "$repo_path")
        fi

        cd "$repo_path" || exit

        # Stage all changes
        if ! git add -A 2>/dev/null; then
            printf "${GW_RED}Error: Could not stage changes for %s${GW_RESET}\n" "$repo_name_display" >&2
            exit 1
        fi

        # Check if there are any staged changes
        if git diff --cached --quiet; then
            printf "${GW_YELLOW}No changes to commit for %s. Skipping...${GW_RESET}\n" "$repo_name_display"
            exit 0
        fi

        # Create the commit
        if commit_output=$(git commit -m "$message" 2>&1); then
            printf "${GW_GREEN}Commit created for %s${GW_RESET}\n" "$repo_name_display"
        else
            printf "${GW_RED}Error: Could not commit changes for %s:\n%s${GW_RESET}\n\n" "$repo_name_display" "$commit_output" >&2
        fi
    )
done <<< "$git_repositories"
