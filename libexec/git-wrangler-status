#!/bin/bash

# ====
# Usage: git-wrangler status
# Description: Shows dirty/clean and ahead/behind status of tracked repositories
# Category: Utility
#
# Iterates through Git repositories found in the current directory and its
# immediate subdirectories and displays a unified dashboard of their real-time
# sync state, dirty/clean working tree status, and commit metrics.
#
# This command takes no arguments.
#
# Example:
#     git-wrangler status
# ====

UI_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
# shellcheck source=libexec/git-wrangler-ui
source "$UI_DIR/git-wrangler-ui"
# shellcheck source=libexec/git-wrangler-core
source "$UI_DIR/git-wrangler-core"


# Parse command-line arguments
while [[ $# -gt 0 ]]; do
  case "$1" in
    *)
      gw_error "Unknown option: $1"
      exit 1
      ;;
  esac
done

gw_require_git "status"

# Find target repositories
git_repositories=$(gw_find_git_repositories)

if [ -z "$git_repositories" ]; then
    gw_warn "No Git repositories found in the specified directory."
    exit 0
fi

# Print table header
printf "%-30s | %-5s | %s\n" "REPOSITORY" "STATE" "TRACKING"
printf "%s\n" "-------------------------------+-------+------------------------"

# Iterate through each repository
status_rows=$(while IFS= read -r git_dir; do
    (
        # Get repository path and display name
        repo_path=$(gw_repo_dir_from_git_dir "$git_dir")
        repo_name_display=$(gw_repo_display_name "$repo_path")

        if [ "${#repo_name_display}" -gt 30 ]; then
            repo_name_display="${repo_name_display:0:27}..."
        fi

        cd "$repo_path" || exit

        status_output=$(git status --porcelain=v2 --branch 2>/dev/null)

        is_dirty=0
        has_upstream=0
        ahead_count=0
        behind_count=0
        is_behind=0
        has_no_remote=0

        while IFS= read -r status_line; do
            case "$status_line" in
                "# branch.upstream "*)
                    has_upstream=1
                    ;;
                "# branch.ab "*)
                    set -- $status_line
                    ahead_count="${3#+}"
                    behind_count="${4#-}"
                    ;;
                "#"*)
                    ;;
                "")
                    ;;
                *)
                    is_dirty=1
                    ;;
            esac
        done <<< "$status_output"

        if [ "$is_dirty" -eq 1 ]; then
            dirty_col="${GW_YELLOW}dirty${GW_RESET}"
        else
            dirty_col="${GW_GREEN}clean${GW_RESET}"
        fi

        if [ "$has_upstream" -eq 0 ]; then
            ab_label="${GW_MUTED}no remote${GW_RESET}"
            has_no_remote=1
        else
            if [ "$ahead_count" -gt 0 ] && [ "$behind_count" -gt 0 ]; then
                ab_label="${GW_CYAN}ahead ${ahead_count}${GW_RESET}, ${GW_RED}behind ${behind_count}${GW_RESET}"
                is_behind=1
            elif [ "$ahead_count" -gt 0 ]; then
                ab_label="${GW_CYAN}ahead ${ahead_count}${GW_RESET}"
            elif [ "$behind_count" -gt 0 ]; then
                ab_label="${GW_RED}behind ${behind_count}${GW_RESET}"
                is_behind=1
            else
                ab_label="up to date"
            fi
        fi

        printf "%s\t%s\t%s\t%d\t%d\t%d\n" "$repo_name_display" "$dirty_col" "$ab_label" "$is_dirty" "$is_behind" "$has_no_remote"
    )
done <<< "$git_repositories")

total_dirty=0
total_behind=0
total_no_remote=0

while IFS=$'\t' read -r repo_name_display dirty_col ab_label is_dirty is_behind has_no_remote; do
    [ -n "$repo_name_display" ] || continue
    printf "%-30s | %b | %b\n" "$repo_name_display" "$dirty_col" "$ab_label"
    ((total_dirty += is_dirty))
    ((total_behind += is_behind))
    ((total_no_remote += has_no_remote))
done <<< "$status_rows"

# Print summary
printf "%s\n" "-------------------------------+-------+------------------------"

printf "Summary: ${GW_YELLOW}%d dirty${GW_RESET}, ${GW_RED}%d behind${GW_RESET}, ${GW_MUTED}%d no remote${GW_RESET}\n" "$total_dirty" "$total_behind" "$total_no_remote" >&2
