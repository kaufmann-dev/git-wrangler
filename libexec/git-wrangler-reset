#!/bin/bash

# ====
# Usage: git-wrangler reset [--confirm]
# Description: Resets the current branch to exactly match its remote counterpart
# Category: Local Operations
#
# Fetches the latest remote state and hard-resets the current branch to
# origin/[current branch], discarding any local commits and uncommitted changes.
# Before resetting, the script shows divergence status (ahead/behind counts) and
# prompts for confirmation unless --confirm is supplied.
#
# Options:
#   --confirm  (optional) Skip the interactive confirmation prompt.
#
# Examples:
#     git-wrangler reset
#     git-wrangler reset --confirm
# ====

UI_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
# shellcheck source=libexec/git-wrangler-ui
source "$UI_DIR/git-wrangler-ui"


confirm=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --confirm)
            confirm=true
            shift
            ;;
        *)
            gw_error "Unknown option: $1"
            exit 1
            ;;
    esac
done

if ! command -v git &> /dev/null; then
    printf "${GW_RED}Error: 'git' is required for reset. Run 'git-wrangler doctor' for more information.${GW_RESET}\n" >&2
    exit 1
fi

git_repositories=$(find . -maxdepth 2 -type d -name '.git')

if [ -z "$git_repositories" ]; then
    gw_warn "No Git repositories found in the specified directory."
    exit 0
fi

while IFS= read -r git_dir; do
    (
        repo_dir=$(dirname "$git_dir")

        if [ "$repo_dir" = "." ]; then
            repo_name_display="${PWD##*/}"
        else
            repo_name_display=$(basename "$repo_dir")
        fi

        cd "$repo_dir" || exit

        current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)

        if [ "$current_branch" = "HEAD" ]; then
            printf "${GW_YELLOW}%s is in detached HEAD state. Skipping...${GW_RESET}\n" "$repo_name_display"
            exit 0
        fi

        if fetch_output=$(git fetch origin "$current_branch" 2>&1); then
            :
        else
            printf "${GW_RED}Error: Fetch failed for %s:\n%s${GW_RESET}\n\n" "$repo_name_display" "$fetch_output" >&2
            exit 1
        fi

        if ! git rev-parse --verify --quiet "origin/$current_branch" >/dev/null 2>&1; then
            printf "${GW_YELLOW}Branch '%s' has no remote counterpart in %s. Skipping...${GW_RESET}\n" "$current_branch" "$repo_name_display"
            exit 0
        fi

        ahead_count=$(git rev-list --count "origin/$current_branch..$current_branch" 2>/dev/null || echo "0")
        behind_count=$(git rev-list --count "$current_branch..origin/$current_branch" 2>/dev/null || echo "0")

        printf "${GW_CYAN}--- %s (%s) ---${GW_RESET}\n" "$repo_name_display" "$current_branch"

        if [ "$ahead_count" -eq 0 ] && [ "$behind_count" -eq 0 ]; then
            printf "${GW_YELLOW}Branch '%s' is already up to date with origin/%s in %s. Nothing to reset.${GW_RESET}\n" "$current_branch" "$current_branch" "$repo_name_display"
            exit 0
        fi

        printf "Divergence: ${GW_CYAN}ahead %s${GW_RESET}, ${GW_RED}behind %s${GW_RESET}\n" "$ahead_count" "$behind_count" >&2

        dirty_check=$(git status --porcelain 2>/dev/null)
        if [ -n "$dirty_check" ]; then
            printf "${GW_RED}Warning: Working tree has uncommitted changes that will be discarded.${GW_RESET}\n" >&2
        fi

        printf "${GW_RED}This will hard reset %s to origin/%s, discarding %s local commit(s).${GW_RESET}\n" "$current_branch" "$current_branch" "$ahead_count" >&2

        if [ "$confirm" != true ]; then
            gw_prompt "Proceed with reset for $repo_name_display?"
            read -r answer < /dev/tty
            if [ "$answer" != "y" ] && [ "$answer" != "Y" ]; then
                printf "${GW_YELLOW}Skipping %s.${GW_RESET}\n" "$repo_name_display"
                exit 0
            fi
        fi

        if reset_output=$(git reset --hard "origin/$current_branch" 2>&1); then
            printf "${GW_GREEN}Successfully reset %s to origin/%s${GW_RESET}\n" "$repo_name_display" "$current_branch"
        else
            printf "${GW_RED}Error: Reset failed for %s:\n%s${GW_RESET}\n\n" "$repo_name_display" "$reset_output" >&2
        fi
    )
done <<< "$git_repositories"
