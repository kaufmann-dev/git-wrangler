#!/bin/bash

# ====
# Usage: git-wrangler pull [--rebase] [--force]
# Description: Pulls the latest changes for all tracked repositories
# Category: Remote Operations
#
# Iterates through Git repositories found in the current directory and its
# immediate subdirectories, and performs a Git pull operation to fetch and
# integrate changes from the remote repository.
#
# Options:
#   --rebase  (optional) Rebase local commits on top of the fetched remote branch instead of merging.
#   --force   (optional) Forcefully pulls changes, overwriting local changes if necessary.
#
# Examples:
#     git-wrangler pull
#     git-wrangler pull --rebase
#     git-wrangler pull --force
# ====

UI_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
# shellcheck source=libexec/git-wrangler-ui
source "$UI_DIR/git-wrangler-ui"


rebase=false
force=false

# Parse command-line arguments
while [[ $# -gt 0 ]]; do
  case "$1" in
    --rebase)
      rebase=true
      shift
      ;;
    --force)
      force=true
      shift
      ;;
    *)
      gw_error "Unknown option: $1"
      exit 1
      ;;
  esac
done

# Check prerequisites
if ! command -v git &> /dev/null; then
    printf "${GW_RED}Error: 'git' is required for pull. Run 'git-wrangler doctor' for more information.${GW_RESET}\n" >&2
    exit 1
fi

# Find target repositories
git_repositories=$(find . -maxdepth 2 -type d -name '.git')

if [ -z "$git_repositories" ]; then
    gw_warn "No Git repositories found in the specified directory."
    exit 0
fi

# Iterate through each repository
while IFS= read -r git_dir; do
    (
        # Get repository path and display name
        repo_path=$(dirname "$git_dir")

        if [ "$repo_path" = "." ]; then
            repo_name_display="${PWD##*/}"
        else
            repo_name_display=$(basename "$repo_path")
        fi

        cd "$repo_path" || exit

        # Build pull arguments
        pull_args=""
        if [ "$rebase" = true ]; then
            pull_args="$pull_args --rebase"
        fi
        if [ "$force" = true ]; then
            pull_args="$pull_args --force"
        fi

        # Perform Git pull
        if pull_output=$(git pull$pull_args 2>&1); then
            if ! printf "%s" "$pull_output" | grep -q "Already up to date"; then
                printf "${GW_GREEN}Git pull completed for %s${GW_RESET}\n" "$repo_name_display"
            else
                printf "${GW_YELLOW}Already up to date for %s. Skipping...${GW_RESET}\n" "$repo_name_display"
            fi
        else
            printf "${GW_RED}Error: Git pull failed for %s:\n%s${GW_RESET}\n\n" "$repo_name_display" "$pull_output" >&2
        fi
    )
done <<< "$git_repositories"
