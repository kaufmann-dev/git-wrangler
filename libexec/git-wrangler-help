#!/bin/bash

# ====
# Usage: git-wrangler help [<subcommand>]
# Description: Displays help information for git-wrangler and its subcommands
# Category: Utility
#
# When run without arguments, displays a categorized overview of all
# available subcommands. When a subcommand name is provided, displays
# detailed documentation for that specific command including its usage,
# description, options, and examples.
#
# Examples:
#     git-wrangler help
#     git-wrangler help clone
#     git-wrangler help rewrite-authors
# ====

UI_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
# shellcheck source=libexec/git-wrangler-ui
source "$UI_DIR/git-wrangler-ui"


DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

# If a subcommand argument is provided, show its documentation
if [ -n "$1" ]; then
    subcommand="$1"
    target="$DIR/git-wrangler-$subcommand"

    if [ ! -f "$target" ] || ! awk '/^# Category:/{found=1} END{exit found ? 0 : 1}' "$target"; then
        printf "${GW_RED}Error: Unknown subcommand '%s'. Run 'git-wrangler help' for a list of available commands.${GW_RESET}\n" "$subcommand" >&2
        exit 1
    fi

    # Extract documentation between # ==== boundaries, strip # prefix, render with formatting
    raw_docs=$(awk '/^# ====/{found++; next} found==1{sub(/^# ?/, ""); print} found>=2{exit}' "$target")

    printf "\n"

    # Render each line with formatting
    while IFS= read -r line; do
        case "$line" in
            "Usage: "*)
                printf "  ${GW_BOLD}Usage:${GW_RESET} %s\n" "${line#Usage: }"
                ;;
            "Description: "*)
                printf "  ${GW_BOLD}Description:${GW_RESET} %s\n" "${line#Description: }"
                ;;
            "Category: "*)
                printf "  ${GW_BOLD}Category:${GW_RESET} %s\n" "${line#Category: }"
                ;;
            "Options:")
                printf "\n  ${GW_BOLD}Options:${GW_RESET}\n"
                ;;
            "Example:")
                printf "\n  ${GW_BOLD}Example:${GW_RESET}\n"
                ;;
            "Examples:")
                printf "\n  ${GW_BOLD}Examples:${GW_RESET}\n"
                ;;
            "  --"*)
                # Option line: bold the flag name, dim the description
                flag=$(printf '%s' "$line" | sed 's/^\(  --[^ ]*\).*/\1/')
                rest="${line#$flag}"
                printf "    ${GW_YELLOW}%s${GW_RESET}%s\n" "$flag" "$rest"
                ;;
            "    "*)
                # Indented continuation line (option description or example)
                printf "  %s\n" "$line"
                ;;
            "")
                printf "\n"
                ;;
            *)
                printf "    %s\n" "$line"
                ;;
        esac
    done <<< "$raw_docs"

    printf "\n"
    exit 0
fi

# Top-level help: dynamically discover and display all subcommands grouped by category
printf "${GW_BOLD}Usage:${GW_RESET} git-wrangler <subcommand> [options]\n\n"
printf "Available subcommands:\n\n"

# Collect unique categories
categories=""
for file in "$DIR"/git-wrangler-*; do
    [ -f "$file" ] || continue
    category=$(awk '/^# Category:/{sub(/^# Category: */, ""); print; exit}' "$file")
    if [ -n "$category" ]; then
        categories=$(printf '%s\n%s' "$categories" "$category")
    fi
done
categories=$(printf '%s' "$categories" | sort -u | sed '/^$/d')

# Print subcommands grouped by category
while IFS= read -r cat; do
    printf "  ${GW_REPO_COLOR}%s${GW_RESET}\n" "$cat"
    for file in "$DIR"/git-wrangler-*; do
        [ -f "$file" ] || continue
        file_category=$(awk '/^# Category:/{sub(/^# Category: */, ""); print; exit}' "$file")
        if [ "$file_category" = "$cat" ]; then
            subcmd=$(basename "$file")
            subcmd="${subcmd#git-wrangler-}"
            description=$(awk '/^# Description:/{sub(/^# Description: */, ""); print; exit}' "$file")
            printf "    %-24s%s\n" "$subcmd" "$description"
        fi
    done
    printf "\n"
done <<< "$categories"

printf "Run 'git-wrangler help <subcommand>' for detailed information about a specific command.\n"
