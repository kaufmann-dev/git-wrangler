#!/bin/bash

# ====
# Usage: git-wrangler clone --user <username> [--visibility <all|public|private>] [--limit <number>] [--into <directory>]
# Description: Clones multiple GitHub repositories for a given user
# Category: Remote Operations
#
# Clones GitHub repositories based on specified criteria (visibility, user,
# limit) and organizes them into a designated directory. Checks for existing
# repositories and skips them automatically. Requires 'gh' (GitHub CLI)
# to be installed and authenticated.
#
# Options:
#   --user <username>                 (required) GitHub username whose repositories to clone.
#   --visibility <all|public|private> (optional) Visibility filter. Default: "all".
#   --limit <number>                  (optional) Maximum number of repositories to clone. Default: 100.
#   --into <directory>                (optional) Target directory for cloned repositories. Default: username.
#
# Example:
#     git-wrangler clone --user myusername --visibility public --into ./repos
# ====

UI_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
# shellcheck source=libexec/git-wrangler-ui
source "$UI_DIR/git-wrangler-ui"
# shellcheck source=libexec/git-wrangler-core
source "$UI_DIR/git-wrangler-core"


visibility="all"
user=""
limit=100
into=""

clone_repository() {
    local repo="$1"
    local repo_name
    repo_name="${repo##*/}"

    if [[ -d "$into/$repo_name" ]]; then
        printf "${GW_YELLOW}%s already exists in %s. Skipping...${GW_RESET}\n" "$repo_name" "$(realpath "$into")"
        return
    fi

    if clone_output=$(gh repo clone "$repo" "$into/$repo_name" 2>&1); then
        printf "${GW_GREEN}Cloned %s into %s${GW_RESET}\n" "$repo_name" "$(realpath "$into/$repo_name")"
    else
        printf "${GW_RED}Error: Failed to clone %s:\n%s${GW_RESET}\n\n" "$repo_name" "$clone_output" >&2
    fi
}

# Parse command-line arguments
while [[ "$#" -gt 0 ]]; do
    case $1 in
        --visibility)
            gw_require_option_value "$1" "$#" "${2-}"
            visibility="$2"
            shift 2
            ;;
        --user)
            gw_require_option_value "$1" "$#" "${2-}"
            user="$2"
            shift 2
            ;;
        --limit)
            gw_require_option_value "$1" "$#" "${2-}"
            limit="$2"
            shift 2
            ;;
        --into)
            gw_require_option_value "$1" "$#" "${2-}"
            into="$2"
            shift 2
            ;;
        *)
            gw_error "Unknown option: $1"
            exit 1
            ;;
    esac
done

# Validate required arguments
if [[ -z "$user" ]]; then
    gw_error "The --user option is required."
    exit 1
fi

# Check prerequisites
gw_require_command gh "clone"
gw_require_git "clone"

# Validate limit option
if [[ ! "$limit" =~ ^[1-9][0-9]*$ ]]; then
    gw_error "--limit must be 1 or greater."
    exit 1
fi

# Validate visibility option
if [[ "$visibility" != "all" && "$visibility" != "public" && "$visibility" != "private" ]]; then
    gw_error "Invalid visibility option. Use 'all', 'public', or 'private'."
    exit 1
fi

# Check authentication for private repositories
if [[ "$visibility" == "private" || "$visibility" == "all" ]]; then
    if ! gh auth status | grep -q "Logged in to .* account $user "; then
        gw_error "You are not logged in as the specified user: $user. Set --visibility to 'public' or use 'gh auth login'."
        exit 1
    fi
fi

# Check if repositories exist for the user
if [[ "$visibility" == "private" || "$visibility" == "public" ]]; then
    if [[ "$(gh repo list "$user" --limit 1 --visibility "$visibility" 2>/dev/null | wc -l)" -eq 0 ]]; then
        gw_error "No $visibility repositories found for '$user'."
        exit 1
    fi
else
    if [[ "$(gh repo list "$user" --limit 1 2>/dev/null | wc -l)" -eq 0 ]]; then
        gw_error "No repositories found for '$user'."
        exit 1
    fi
fi

# Set default into directory if not specified
if [[ -z "$into" ]]; then
    into="$user"
fi

# Create or access the target directory
if [[ -d "$into" && ! -w "$into" ]] || ! mkdir -p "$into"; then
    gw_error "Unable to create or access the specified directory '$into'."
    exit 1
fi

# Clone repositories based on visibility
if [[ "$visibility" == "public" || "$visibility" == "private" ]]; then
    while IFS=$'\t' read -r repo _; do
        clone_repository "$repo"
    done < <(gh repo list "$user" --visibility "$visibility" --limit "$limit")
else
    while IFS=$'\t' read -r repo _; do
        clone_repository "$repo"
    done < <(gh repo list "$user" --limit "$limit")
fi
