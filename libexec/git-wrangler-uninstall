#!/bin/bash

# ====
# Usage: git-wrangler uninstall [--confirm]
# Description: Uninstalls Git Wrangler from the system
# Category: Utility
#
# Removes the Git Wrangler installation directory and the git-wrangler symlink
# from the bin directory. Prompts for confirmation before proceeding unless
# --confirm is supplied.
#
# Options:
#   --confirm  (optional) Skip the interactive confirmation prompt.
#
# Example:
#     git-wrangler uninstall
#     git-wrangler uninstall --confirm
# ====

UI_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
# shellcheck source=libexec/git-wrangler-ui
source "$UI_DIR/git-wrangler-ui"


confirm=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --confirm)
            confirm=true
            shift
            ;;
        *)
            gw_error "Unknown option: $1"
            exit 1
            ;;
    esac
done

# ── Resolve install and bin directories ──────────────────────────────────────

# The install dir is the parent of libexec/ (where this script lives)
INSTALL_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." && pwd )"

# Resolve the bin dir using the same logic as install.sh
if [ -n "${GIT_WRANGLER_BIN_DIR:-}" ]; then
    BIN_DIR="$GIT_WRANGLER_BIN_DIR"
else
    local_bin="$HOME/.local/bin"
    if [ -d "$local_bin" ]; then
        BIN_DIR="$local_bin"
    elif [ -d "/usr/local/bin" ] && [ -w "/usr/local/bin" ]; then
        BIN_DIR="/usr/local/bin"
    else
        BIN_DIR="$local_bin"
    fi
fi

LINK_TARGET="$BIN_DIR/git-wrangler"

# ── Show what will be removed ────────────────────────────────────────────────

printf "${GW_YELLOW}This will remove Git Wrangler from your system:${GW_RESET}\n\n"

if [ -d "$INSTALL_DIR" ]; then
    printf "  Installation directory: %s\n" "$INSTALL_DIR"
fi

if [ -L "$LINK_TARGET" ]; then
    printf "  Symlink:               %s\n" "$LINK_TARGET"
fi

printf "\n"

# ── Confirm ──────────────────────────────────────────────────────────────────

if [ "$confirm" != true ]; then
    gw_prompt "Are you sure you want to uninstall?"
    read -r answer < /dev/tty
    if [ "$answer" != "y" ] && [ "$answer" != "Y" ]; then
        printf "${GW_YELLOW}Aborted.${GW_RESET}\n"
        exit 0
    fi
    printf "\n"
fi

# ── Remove symlink ───────────────────────────────────────────────────────────

if [ -L "$LINK_TARGET" ]; then
    rm "$LINK_TARGET"
    printf "${GW_GREEN}${GW_OK_SYMBOL} Removed symlink %s${GW_RESET}\n" "$LINK_TARGET"
elif [ -e "$LINK_TARGET" ]; then
    printf "${GW_YELLOW}${GW_WARN_SYMBOL} %s exists but is not a symlink - skipping${GW_RESET}\n" "$LINK_TARGET"
fi

# ── Remove installation directory ────────────────────────────────────────────

if [ -d "$INSTALL_DIR" ]; then
    rm -rf "$INSTALL_DIR"
    printf "${GW_GREEN}${GW_OK_SYMBOL} Removed %s${GW_RESET}\n" "$INSTALL_DIR"
fi

printf "\n${GW_GREEN}${GW_OK_SYMBOL} Git Wrangler uninstalled.${GW_RESET}\n\n"
