#!/bin/bash

# Shared non-UI helpers for git-wrangler commands.

gw_require_option_value() {
    local option="$1"
    local argc="$2"
    local value="${3-}"

    if [ "$argc" -lt 2 ] || [ -z "$value" ] || [[ "$value" == --* ]]; then
        gw_error "$option requires a value."
        exit 1
    fi
}

gw_require_command() {
    local command_name="$1"
    local context="$2"

    if ! command -v "$command_name" &> /dev/null; then
        gw_error "'$command_name' is required for $context. Run 'git-wrangler doctor' for more information."
        exit 1
    fi
}

gw_require_git() {
    gw_require_command git "$1"
}

gw_find_git_repositories() {
    local root="${1:-.}"
    find "$root" -maxdepth 2 -type d -name '.git'
}

gw_repo_dir_from_git_dir() {
    local git_dir="$1"

    if [ "$git_dir" = ".git" ] || [ "$git_dir" = "./.git" ]; then
        printf ".\n"
    else
        printf "%s\n" "${git_dir%/.git}"
    fi
}

gw_repo_display_name() {
    local repo_dir="$1"
    local trimmed="${repo_dir%/}"
    local name

    if [ "$trimmed" = "." ]; then
        name="${PWD##*/}"
    else
        name="${trimmed##*/}"
    fi

    printf "%s\n" "$name"
}

gw_require_filter_repo() {
    local context="$1"

    gw_filter_repo_cmd=()
    if command -v git-filter-repo &> /dev/null; then
        gw_filter_repo_cmd=(git-filter-repo)
    elif git filter-repo --version &> /dev/null; then
        gw_filter_repo_cmd=(git filter-repo)
    else
        gw_error "'git-filter-repo' is required for $context. Run 'git-wrangler doctor' for more information."
        exit 1
    fi
}

gw_confirm() {
    local question="$1"
    local answer

    gw_prompt "$question"
    if [ -r /dev/tty ]; then
        IFS= read -r answer < /dev/tty
    else
        IFS= read -r answer
    fi

    [ "$answer" = "y" ] || [ "$answer" = "Y" ]
}

gw_cpu_count() {
    local count

    count=$(getconf _NPROCESSORS_ONLN 2>/dev/null || true)
    if [ -z "$count" ] && command -v sysctl >/dev/null 2>&1; then
        count=$(sysctl -n hw.ncpu 2>/dev/null || true)
    fi

    case "$count" in
        ''|*[!0-9]*|0)
            printf "1\n"
            ;;
        *)
            printf "%s\n" "$count"
            ;;
    esac
}
