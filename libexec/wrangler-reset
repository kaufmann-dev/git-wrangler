#!/bin/bash

# ====
# Usage: wrangler reset [--confirm]
# Description: Resets the current branch to exactly match its remote counterpart
# Category: Local Operations
#
# Fetches the latest remote state and hard-resets the current branch to
# origin/[current branch], discarding any local commits and uncommitted changes.
# Before resetting, the script shows divergence status (ahead/behind counts) and
# prompts for confirmation unless --confirm is supplied.
#
# Options:
#   --confirm  (optional) Skip the interactive confirmation prompt.
#
# Examples:
#     wrangler reset
#     wrangler reset --confirm
# ====

confirm=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --confirm)
            confirm=true
            shift
            ;;
        *)
            printf "\e[31mUnknown option: %s\e[0m\n" "$1"
            exit 1
            ;;
    esac
done

if ! command -v git &> /dev/null; then
    printf "\e[31mError: 'git' is not installed. Please install it first.\e[0m\n"
    exit 1
fi

git_repositories=$(find . -maxdepth 2 -type d -name '.git')

if [ -z "$git_repositories" ]; then
    printf "\e[33mNo Git repositories found in the specified directory.\e[0m\n"
    exit 0
fi

while IFS= read -r git_dir; do
    (
        repo_dir=$(dirname "$git_dir")

        if [ "$repo_dir" = "." ]; then
            repo_name_display="${PWD##*/}"
        else
            repo_name_display=$(basename "$repo_dir")
        fi

        cd "$repo_dir" || exit

        current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)

        if [ "$current_branch" = "HEAD" ]; then
            printf "\e[33m%s is in detached HEAD state. Skipping...\e[0m\n" "$repo_name_display"
            exit 0
        fi

        if fetch_output=$(git fetch origin "$current_branch" 2>&1); then
            :
        else
            printf "\e[31mError: Fetch failed for %s:\n%s\e[0m\n\n" "$repo_name_display" "$fetch_output"
            exit 1
        fi

        if ! git rev-parse --verify --quiet "origin/$current_branch" >/dev/null 2>&1; then
            printf "\e[33mBranch '%s' has no remote counterpart in %s. Skipping...\e[0m\n" "$current_branch" "$repo_name_display"
            exit 0
        fi

        ahead_count=$(git rev-list --count "origin/$current_branch..$current_branch" 2>/dev/null || echo "0")
        behind_count=$(git rev-list --count "$current_branch..origin/$current_branch" 2>/dev/null || echo "0")

        printf "\e[36m--- %s (%s) ---\e[0m\n" "$repo_name_display" "$current_branch"

        if [ "$ahead_count" -eq 0 ] && [ "$behind_count" -eq 0 ]; then
            printf "\e[33mBranch '%s' is already up to date with origin/%s in %s. Nothing to reset.\e[0m\n" "$current_branch" "$current_branch" "$repo_name_display"
            exit 0
        fi

        printf "Divergence: \e[36mahead %s\e[0m, \e[31mbehind %s\e[0m\n" "$ahead_count" "$behind_count"

        dirty_check=$(git status --porcelain 2>/dev/null)
        if [ -n "$dirty_check" ]; then
            printf "\e[31mWarning: Working tree has uncommitted changes that will be discarded.\e[0m\n"
        fi

        printf "\e[31mThis will hard reset %s to origin/%s, discarding %s local commit(s).\e[0m\n" "$current_branch" "$current_branch" "$ahead_count"

        if [ "$confirm" != true ]; then
            printf "Proceed with reset for %s? [y/N] " "$repo_name_display"
            read -r answer < /dev/tty
            if [ "$answer" != "y" ] && [ "$answer" != "Y" ]; then
                printf "\e[33mSkipping %s.\e[0m\n" "$repo_name_display"
                exit 0
            fi
        fi

        if reset_output=$(git reset --hard "origin/$current_branch" 2>&1); then
            printf "\e[32mSuccessfully reset %s to origin/%s\e[0m\n" "$repo_name_display" "$current_branch"
        else
            printf "\e[31mError: Reset failed for %s:\n%s\e[0m\n\n" "$repo_name_display" "$reset_output"
        fi
    )
done <<< "$git_repositories"
