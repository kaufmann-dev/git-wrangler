#!/bin/bash

# ====
# Usage: git-wrangler remove-secrets --confirm
# Description: Permanently purges sensitive files from the entire Git history
# Category: History Rewriting
#
# Permanently purges files containing sensitive data from the entire Git
# history of all managed repositories (across all branches and tags).
# Scans for common secret file patterns (.env, *.pem, *.key, id_rsa, etc.)
# and removes any matches using git-filter-repo. Requires 'git-filter-repo'
# to be installed. The remote origin URL is automatically restored after
# the rewrite.
#
# The list of target patterns is hardcoded in the script. --confirm is
# required before any destructive history rewrite is performed.
#
# Options:
#   --confirm  (required) Confirm noninteractive history rewriting.
#
# Example:
#     git-wrangler remove-secrets --confirm
# ====

UI_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
# shellcheck source=libexec/git-wrangler-ui
source "$UI_DIR/git-wrangler-ui"
# shellcheck source=libexec/git-wrangler-core
source "$UI_DIR/git-wrangler-core"


# List of files and patterns to purge from Git history
TARGET_PATTERNS=(
    ".env"
    ".env.*"
    "*.pem"
    "*.key"
    "*.p12"
    "*.pfx"
    "id_rsa"
    "id_rsa.pub"
    "id_ed25519"
    "id_ed25519.pub"
    "config.json"
    "secrets.json"
    "credentials.json"
    "*.secret"
)
confirm=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --confirm)
            confirm=true
            shift
            ;;
        *)
            gw_error "Unknown option: $1"
            exit 1
            ;;
    esac
done

gw_require_git "remove-secrets"
gw_require_filter_repo "remove-secrets"
filter_repo_cmd=("${gw_filter_repo_cmd[@]}")

# Find target repositories
git_repositories=$(gw_find_git_repositories)

if [ -z "$git_repositories" ]; then
    gw_warn "No Git repositories found in the specified directory."
    exit 0
fi

# Iterate through each repository
while IFS= read -r git_dir; do
    (
        # Get repository path and display name
        repo_path=$(gw_repo_dir_from_git_dir "$git_dir")
        repo_name_display=$(gw_repo_display_name "$repo_path")

        # Check repository accessibility
        if ! cd "$repo_path" 2>/dev/null || ! git rev-parse --is-inside-work-tree &> /dev/null; then
            printf "${GW_RED}Error: %s is not a valid or accessible git repository. Skipping...${GW_RESET}\n" "$repo_name_display" >&2
            exit 1
        fi

        # Scan for matched patterns anywhere in the history
        matched_patterns=()
        matched_files=()
        for pattern in "${TARGET_PATTERNS[@]}"; do
            if matches=$(git log --all --oneline -- "$pattern" 2>/dev/null | head -n 1) && [ -n "$matches" ]; then
                matched_patterns+=("$pattern")
                while IFS= read -r filepath; do
                    if [ -n "$filepath" ]; then
                        matched_files+=("$filepath")
                    fi
                done < <(git log --all --format="" --name-only -- "$pattern" 2>/dev/null | sort -u)
            fi
        done

        if [ ${#matched_patterns[@]} -eq 0 ]; then
            printf "${GW_YELLOW}No target patterns found in history. Skipping %s cleanly...${GW_RESET}\n" "$repo_name_display"
            exit 0
        fi

        printf "${GW_YELLOW}Found %d sensitive file(s) matching %d pattern(s) in %s:${GW_RESET}\n" "${#matched_files[@]}" "${#matched_patterns[@]}" "$repo_name_display"
        for filepath in "${matched_files[@]}"; do
            printf "  %s\n" "$filepath"
        done
        printf "\n"

        if [ "$confirm" != true ]; then
            gw_error "$repo_name_display" "Refusing to rewrite history without --confirm."
            exit 1
        fi

        # Prepare filter-repo arguments
        filter_repo_args=()
        for pattern in "${matched_patterns[@]}"; do
            filter_repo_args+=(--path-glob "$pattern")
        done

        # Capture remote origin URL before rewriting (filter-repo drops it)
        remote_url=$(git remote get-url origin 2>/dev/null)

        # Execute history rewrite using git filter-repo
        # We pass --force to git-filter-repo to bypass the fresh-clone requirement. The script is
        # explicitly intended to run on the current working repositories without user friction.
        if error_message=$("${filter_repo_cmd[@]}" "${filter_repo_args[@]}" --invert-paths --use-base-name --partial --force 2>&1 >/dev/null); then
            printf "${GW_GREEN}Successfully purged %d sensitive file(s) from %s${GW_RESET}\n" "${#matched_files[@]}" "$repo_name_display"
        else
            printf "${GW_RED}Error: Rewrite failed for %s:\n%s${GW_RESET}\n\n" "$repo_name_display" "$error_message" >&2
            exit 1
        fi

        # Restore original remote origin if applicable
        if [ -n "$remote_url" ]; then
            git remote add origin "$remote_url" 2>/dev/null
        fi
    )
done <<< "$git_repositories"
