#!/bin/bash

# ====
# Usage: git-wrangler info [--repo <repository_name>]
# Description: Displays detailed information about tracked repositories
# Category: Utility
#
# Iterates through Git repositories found in the current directory and its
# immediate subdirectories, and provides detailed information about each
# repository including name, status, license, branches, remotes, commits,
# top authors, and largest files in history.
#
# Options:
#   --repo <repository_name>  (optional) Analyze a single repository instead of all in the current directory.
#
# Examples:
#     git-wrangler info
#     git-wrangler info --repo my-project
# ====

UI_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
# shellcheck source=libexec/git-wrangler-ui
source "$UI_DIR/git-wrangler-ui"
# shellcheck source=libexec/git-wrangler-core
source "$UI_DIR/git-wrangler-core"


repo=""

# Parse command-line arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --repo)
            gw_require_option_value "$1" "$#" "${2-}"
            repo="$2"
            shift 2
            ;;
        *)
            gw_error "Unknown option: $1"
            exit 1
            ;;
    esac
done

gw_require_git "info"

# Find target repositories
if [ -n "$repo" ]; then
    git_repositories=$(gw_find_git_repositories "$repo")
else
    git_repositories=$(gw_find_git_repositories)
fi

if [ -z "$git_repositories" ]; then
    gw_warn "No Git repositories found in the specified directory."
    exit 0
fi

# Iterate through each repository
while IFS= read -r git_dir; do
    (
        repo_name=$(gw_repo_dir_from_git_dir "$git_dir")
        repo_name_display=$(gw_repo_display_name "$repo_name")
        cd "$repo_name" || exit

        printf "Repository:         ${GW_REPO_COLOR}%s${GW_RESET}\n" "$repo_name_display"

        status=$(git status --porcelain 2>/dev/null)
        if [ -z "$status" ]; then
            printf "Status:             ${GW_GREEN}Clean${GW_RESET}\n"
        else
            printf "Status:             ${GW_YELLOW}Dirty (uncommitted changes or untracked files)${GW_RESET}\n"
        fi

        printf "License:            "
        if [ -f "LICENSE" ]; then
            first_line=$(head -n 1 "LICENSE")
            if [ -z "$first_line" ]; then
                printf "${GW_GREEN}Yes${GW_RESET}\n"
            else
                if [ ${#first_line} -gt 70 ]; then
                    first_line="${first_line:0:67}..."
                fi
                printf "${GW_GREEN}'%s'${GW_RESET}\n" "$first_line"
            fi
        else
            printf "${GW_YELLOW}None${GW_RESET}\n"
        fi

        current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
        printf "Current branch:     %s\n" "$current_branch"

        has_commits=false
        if git rev-parse HEAD >/dev/null 2>&1; then
            has_commits=true
        fi

        ahead_behind=$(git rev-list --left-right --count HEAD..."@{u}" 2>/dev/null)
        if [ -n "$ahead_behind" ]; then
            set -- $ahead_behind
            ahead="$1"
            behind="$2"
            printf "Ahead/behind:       %s ahead, %s behind remote\n" "$ahead" "$behind"
        else
            printf "Ahead/behind:       No upstream set\n"
        fi

        branches=$(git branch -a --no-color | awk '!/remotes/{sub(/^\* /, ""); sub(/^[[:space:]]*/, ""); print}')
        branch_count=$(printf "%s\n" "$branches" | awk 'NF{count++} END{print count+0}')
        printf "Branches ($branch_count):       "
        printf "%s\n" "$branches" | awk 'NR==1{print; next} {printf "%-20s%s\n", "", $0}'

        remotes=$(git remote -v | awk '{print $1 " " $2}' | sort -u)
        if [ -n "$remotes" ]; then
            printf "Remotes:            %s\n" "$(printf "%s\n" "$remotes" | awk 'NR==1{print $2} NR>1{printf "%-20s%s\n", "", $2}')"
        else
            printf "Remotes:            None\n"
        fi

        initial_commit=$(git log --reverse --format="%ci - %s" 2>/dev/null | head -n 1)
        if [ "$has_commits" = true ] && [ -n "$initial_commit" ]; then
            printf "Initial commit:     %s\n" "$initial_commit"
        else
            printf "Initial commit:     None (repository is empty)\n"
        fi

        commit_count=$(git rev-list --all --count)
        printf "Total commits:      %s\n" "$commit_count"

        commit_freq=$(git log --since="1 month ago" --format="%ci" 2>/dev/null | wc -l | tr -d '[:space:]')
        printf "Commits last month: %s\n" "$commit_freq"

        last_commit=$(git log -1 --format="%ci - %s" 2>/dev/null)
        printf "Last commit:        %s\n" "$last_commit"

        if [ "$has_commits" = true ]; then
            printf "Top authors:        "
            git log --format='%an <%ae>' 2>/dev/null | sort | uniq -c | sort -rn | head -n 3 | awk '{
                count = $1;
                sub(/^[ \t]*[0-9]+[ \t]*/, "");
                name_email = $0;
                if (NR == 1) { printf "%s - %s\n", count, name_email }
                else { printf "%-20s%s - %s\n", "", count, name_email }
            }'
        else
            printf "Top authors:        None (repository is empty)\n"
        fi

        git rev-list --objects --all 2>/dev/null | git cat-file --batch-check='%(objectsize) %(objectname) %(rest)' | sort -nr | awk '
        BEGIN { first = 1 }
        {
            size = $1; object = $2; path = ($3 != "" ? $3 : "");
            if (path != "" && !(path in seen)) {
                seen[path] = 1;
                if (size >= 1073741824) { size_str = sprintf("%.2f GB", size/1073741824) }
                else if (size >= 1048576) { size_str = sprintf("%.2f MB", size/1048576) }
                else if (size >= 1024) { size_str = sprintf("%.2f KB", size/1024) }
                else { size_str = sprintf("%d bytes", size) }
                if (first) { printf "Largest files:      %s - %s\n", size_str, path; first = 0; }
                else { printf "%-20s%s - %s\n", "", size_str, path; }
            }
        }' | head -n 3

        printf -- "\n"
    )
done <<< "$git_repositories"
