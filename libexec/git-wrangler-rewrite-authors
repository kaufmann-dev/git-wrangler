#!/bin/bash

# ====
# Usage: git-wrangler rewrite-authors --name <new_name> --email <new_email> [--force] [--repo <repository_name>]
# Description: Rewrites author and committer names and emails across repositories
# Category: History Rewriting
#
# Iterates through Git repositories found in the current directory and its
# immediate subdirectories, and rewrites all author and committer information
# using git-filter-repo. Requires 'git-filter-repo' to be installed. The
# remote origin URL is automatically restored after the rewrite.
#
# Options:
#   --name <new_name>          (required) The new name to set as author and committer.
#   --email <new_email>        (required) The new email to set as author and committer.
#   --force                    (optional) Allow rewriting even if the repository does not look like a fresh clone.
#   --repo <repository_name>   (optional) Target a single repository instead of all in the current directory.
#
# Example:
#     git-wrangler rewrite-authors --name "New Name" --email "new@email.com" --force
# ====

UI_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
# shellcheck source=libexec/git-wrangler-ui
source "$UI_DIR/git-wrangler-ui"
# shellcheck source=libexec/git-wrangler-core
source "$UI_DIR/git-wrangler-core"


force=false
repo=""
NEW_NAME=""
NEW_EMAIL=""

# Parse command-line arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --name)
            gw_require_option_value "$1" "$#" "${2-}"
            NEW_NAME="$2"
            shift 2
            ;;
        --email)
            gw_require_option_value "$1" "$#" "${2-}"
            NEW_EMAIL="$2"
            shift 2
            ;;
        --force)
            force=true
            shift
            ;;
        --repo)
            gw_require_option_value "$1" "$#" "${2-}"
            repo="$2"
            shift 2
            ;;
        *)
            gw_error "Unknown option: $1"
            exit 1
            ;;
    esac
done

# Validate required arguments
if [[ -z "$NEW_NAME" || -z "$NEW_EMAIL" ]]; then
    printf "${GW_RED}Error: Both --name and --email options must be provided.${GW_RESET}\n" >&2
    exit 1
fi

gw_require_git "rewrite-authors"
gw_require_filter_repo "rewrite-authors"
filter_repo_cmd=("${gw_filter_repo_cmd[@]}")

# Find target repositories
if [ -n "$repo" ]; then
    repos=$(gw_find_git_repositories "$repo")
else
    repos=$(gw_find_git_repositories)
fi

if [ -z "$repos" ]; then
    gw_warn "No Git repositories found in the specified directory."
    exit 0
fi

# Iterate through each repository
while IFS= read -r repo; do
    (
        # Get repository directory and name
        repo_dir=$(gw_repo_dir_from_git_dir "$repo")
        repo_name_display=$(gw_repo_display_name "$repo_dir")

        cd "$repo_dir" || exit

        # Capture remote origin URL before rewriting (filter-repo drops it)
        remote_url=$(git remote get-url origin 2>/dev/null)

        # Update author and committer information using git-filter-repo
        if [ "$force" = true ]; then
            if error_message=$(NEW_EMAIL_ENV="$NEW_EMAIL" NEW_NAME_ENV="$NEW_NAME" "${filter_repo_cmd[@]}" --partial --force --email-callback 'import os; return os.environ["NEW_EMAIL_ENV"].encode("utf-8")' --name-callback 'import os; return os.environ["NEW_NAME_ENV"].encode("utf-8")' 2>&1 >/dev/null); then
                if [ -n "$remote_url" ] && ! git remote get-url origin >/dev/null 2>&1; then
                    if ! restore_output=$(git remote add origin "$remote_url" 2>&1); then
                        printf "${GW_RED}Warning: Author rewrite completed for %s, but origin could not be restored:\n%s${GW_RESET}\n\n" "$repo_name_display" "$restore_output" >&2
                        exit 1
                    fi
                fi
                printf "${GW_GREEN}Author and commiter information updated for %s${GW_RESET}\n" "$repo_name_display"
            else
                printf "${GW_RED}Error: Could not update git author and commiter information for %s:\n%s${GW_RESET}\n\n" "$repo_name_display" "$error_message" >&2
            fi
        else
            if error_message=$(NEW_EMAIL_ENV="$NEW_EMAIL" NEW_NAME_ENV="$NEW_NAME" "${filter_repo_cmd[@]}" --partial --email-callback 'import os; return os.environ["NEW_EMAIL_ENV"].encode("utf-8")' --name-callback 'import os; return os.environ["NEW_NAME_ENV"].encode("utf-8")' 2>&1 >/dev/null); then
                if [ -n "$remote_url" ] && ! git remote get-url origin >/dev/null 2>&1; then
                    if ! restore_output=$(git remote add origin "$remote_url" 2>&1); then
                        printf "${GW_RED}Warning: Author rewrite completed for %s, but origin could not be restored:\n%s${GW_RESET}\n\n" "$repo_name_display" "$restore_output" >&2
                        exit 1
                    fi
                fi
                printf "${GW_GREEN}Author and commiter information updated for %s${GW_RESET}\n" "$repo_name_display"
            else
                printf "${GW_RED}Error: Could not update git author and commiter information for %s:\n%s${GW_RESET}\n\n" "$repo_name_display" "$error_message" >&2
            fi
        fi
    )
done <<< "$repos"
