#!/bin/bash

# ====
# Usage: git-wrangler rename-repo [--description]
# Description: Bulk renames GitHub repositories and optionally updates their descriptions.
# Category: Remote Operations
#
# Iterates through Git repositories found in the current directory and its
# immediate subdirectories. For each repository, it retrieves the current name
# from GitHub and prompts for a new name. If --description is provided, it
# also retrieves the current description and prompts for a new one.
#
# Options:
#   --description  (optional) Also prompt to update the repository description.
#
# Examples:
#     git-wrangler rename-repo
#     git-wrangler rename-repo --description
# ====

UI_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
# shellcheck source=libexec/git-wrangler-ui
source "$UI_DIR/git-wrangler-ui"
# shellcheck source=libexec/git-wrangler-core
source "$UI_DIR/git-wrangler-core"


edit_description=false

# Parse command-line arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --description)
            edit_description=true
            shift
            ;;
        *)
            gw_error "Unknown option: $1"
            exit 1
            ;;
    esac
done

gw_require_git "rename-repo"
gw_require_command gh "rename-repo"

# Find target repositories
git_repositories=$(gw_find_git_repositories)

if [ -z "$git_repositories" ]; then
    gw_warn "No Git repositories found in the current directory or its immediate subdirectories."
    exit 0
fi

# Iterate through each repository
while IFS= read -r git_dir; do
    (
        repo_dir=$(gw_repo_dir_from_git_dir "$git_dir")
        cd "$repo_dir" || exit

        repo_name_display=$(gw_repo_display_name "$repo_dir")

        # Get old name from github
        if ! old_name=$(gh repo view --json name -q .name 2>/dev/null); then
            printf "${GW_YELLOW}Skipping %s: No remote or not a GitHub repository.${GW_RESET}\n" "$repo_name_display"
            exit 0 # exit subshell, continuing loop
        fi

        printf "\n${GW_REPO_COLOR}Repository: %s${GW_RESET}\n" "$old_name"
        read -r -p "Enter new name (leave blank to skip): " new_name < /dev/tty

        new_desc=""
        if [ "$edit_description" = true ]; then
            old_desc=$(gh repo view --json description -q .description 2>/dev/null)
            if [ -z "$old_desc" ]; then
                printf "Current description: <None>\n"
            else
                printf "Current description: %s\n" "$old_desc"
            fi
            read -r -p "Enter new description (leave blank to skip): " new_desc < /dev/tty
        fi

        if [ "$edit_description" = true ] && [ -n "$new_desc" ]; then
            if command_output=$(gh repo edit --description "$new_desc" 2>&1); then
                printf "${GW_GREEN}Successfully updated description for %s${GW_RESET}\n" "$old_name"
            else
                printf "${GW_RED}Error: Failed to update description for %s:\n%s${GW_RESET}\n" "$old_name" "$command_output" >&2
            fi
        fi

        if [ -n "$new_name" ]; then
            if command_output=$(gh repo rename "$new_name" --yes 2>&1); then
                printf "${GW_GREEN}Successfully renamed %s to %s${GW_RESET}\n" "$old_name" "$new_name"
            else
                printf "${GW_RED}Error: Failed to rename %s:\n%s${GW_RESET}\n" "$old_name" "$command_output" >&2
            fi
        fi
    )
done <<< "$git_repositories"
