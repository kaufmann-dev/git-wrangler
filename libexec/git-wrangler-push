#!/bin/bash

# ====
# Usage: git-wrangler push [--force] [--force-unsafe]
# Description: Pushes local commits to remote for all tracked repositories
# Category: Remote Operations
#
# Iterates through Git repositories found in the current directory and its
# immediate subdirectories, checks if there are changes to push, and performs
# a Git push operation with optional force flag. --force uses
# --force-with-lease; --force-unsafe performs a raw force push after
# confirmation.
#
# Options:
#   --force         (optional) Forcefully pushes changes using --force-with-lease.
#   --force-unsafe  (optional) Performs a raw --force push after confirmation.
#
# Examples:
#     git-wrangler push
#     git-wrangler push --force
#     git-wrangler push --force-unsafe
# ====

UI_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
# shellcheck source=libexec/git-wrangler-ui
source "$UI_DIR/git-wrangler-ui"
# shellcheck source=libexec/git-wrangler-core
source "$UI_DIR/git-wrangler-core"


force=false
force_unsafe=false

# Parse command-line arguments
while [[ $# -gt 0 ]]; do
  case "$1" in
    --force)
      force=true
      shift
      ;;
    --force-unsafe)
      force_unsafe=true
      shift
      ;;
    *)
      gw_error "Unknown option: $1"
      exit 1
      ;;
  esac
done

if [ "$force" = true ] && [ "$force_unsafe" = true ]; then
    gw_error "Use either --force or --force-unsafe, not both."
    exit 1
fi

gw_require_git "push"

# Find target repositories
git_repositories=$(gw_find_git_repositories)

if [ -z "$git_repositories" ]; then
    gw_warn "No Git repositories found in the specified directory."
    exit 0
fi

# Iterate through each repository
while IFS= read -r git_dir; do
    (
        # Get repository path and display name
        repo_path=$(gw_repo_dir_from_git_dir "$git_dir")
        repo_name_display=$(gw_repo_display_name "$repo_path")

        cd "$repo_path" || exit

        push_args=(push origin HEAD)
        if [ "$force" = true ]; then
            push_args=(push --force-with-lease origin HEAD)
        elif [ "$force_unsafe" = true ]; then
            if ! gw_confirm "Raw force push $repo_name_display with --force?"; then
                gw_skip "$repo_name_display" "Skipping unsafe force push."
                exit 0
            fi
            push_args=(push --force origin HEAD)
        fi

        if push_output=$(git "${push_args[@]}" 2>&1); then
            case "$push_output" in
                *"Everything up-to-date"*)
                    gw_skip "$repo_name_display" "No changes to push. Skipping..."
                    ;;
                *)
                    gw_ok "$repo_name_display" "Git push completed"
                    ;;
            esac
        else
            gw_error "$repo_name_display" "Git push failed:"
            printf "%s\n\n" "$push_output" >&2
        fi
    )
done <<< "$git_repositories"
