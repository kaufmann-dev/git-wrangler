#!/bin/bash

# ====
# Usage: git-wrangler push [--force]
# Description: Pushes local commits to remote for all tracked repositories
# Category: Remote Operations
#
# Iterates through Git repositories found in the current directory and its
# immediate subdirectories, checks if there are changes to push, and performs
# a Git push operation with optional force flag.
#
# Options:
#   --force  (optional) Forcefully pushes changes, overwriting remote branches if necessary.
#
# Examples:
#     git-wrangler push
#     git-wrangler push --force
# ====

UI_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
# shellcheck source=libexec/git-wrangler-ui
source "$UI_DIR/git-wrangler-ui"


force=false

# Parse command-line arguments
while [[ $# -gt 0 ]]; do
  case "$1" in
    --force)
      force=true
      shift
      ;;
    *)
      gw_error "Unknown option: $1"
      exit 1
      ;;
  esac
done

# Check prerequisites
if ! command -v git &> /dev/null; then
    printf "${GW_RED}Error: 'git' is required for push. Run 'git-wrangler doctor' for more information.${GW_RESET}\n" >&2
    exit 1
fi

# Find target repositories
git_repositories=$(find . -maxdepth 2 -type d -name '.git')

if [ -z "$git_repositories" ]; then
    gw_warn "No Git repositories found in the specified directory."
    exit 0
fi

# Iterate through each repository
while IFS= read -r git_dir; do
    (
        # Get repository path and display name
        repo_path=$(dirname "$git_dir")

        if [ "$repo_path" = "." ]; then
            repo_name_display="${PWD##*/}"
        else
            repo_name_display=$(basename "$repo_path")
        fi

        cd "$repo_path" || exit

        # Perform Git push based on force flag
        if [ "$force" = true ]; then
            if push_output=$(git push --force origin HEAD 2>&1); then
                if ! printf "%s" "$push_output" | grep -q "Everything up-to-date"; then
                    printf "${GW_GREEN}Git push completed for %s${GW_RESET}\n" "$repo_name_display"
                else
                    printf "${GW_YELLOW}No changes to push for %s. Skipping...${GW_RESET}\n" "$repo_name_display"
                fi
            else
                printf "${GW_RED}Error: Git push failed for %s:\n%s${GW_RESET}\n\n" "$repo_name_display" "$push_output" >&2
            fi
        else
            if push_output=$(git push origin HEAD 2>&1); then
                if ! printf "%s" "$push_output" | grep -q "Everything up-to-date"; then
                    printf "${GW_GREEN}Git push completed for %s${GW_RESET}\n" "$repo_name_display"
                else
                    printf "${GW_YELLOW}No changes to push for %s. Skipping...${GW_RESET}\n" "$repo_name_display"
                fi
            else
                printf "${GW_RED}Error: Git push failed for %s:\n%s${GW_RESET}\n\n" "$repo_name_display" "$push_output" >&2
            fi
        fi
    )
done <<< "$git_repositories"
