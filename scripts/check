#!/bin/bash

set -u

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT" || exit 1

status=0

step() {
    printf "==> %s\n" "$1"
}

step "go test"
if ! go test ./...; then
    status=1
fi

step "go test -race"
if ! go test -race ./...; then
    status=1
fi

step "go vet"
if ! go vet ./...; then
    status=1
fi

if command -v goreleaser >/dev/null 2>&1; then
    step "goreleaser check"
    if ! goreleaser check; then
        status=1
    fi
else
    printf "skip goreleaser check: goreleaser is not installed\n"
fi

if [ -x website/node_modules/.bin/astro ]; then
    step "website build"
    if ! (cd website && ./node_modules/.bin/astro build); then
        status=1
    fi
else
    printf "skip website build: website dependencies not installed\n"
fi

exit "$status"
