#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────────────────────
# Git Wrangler — Installer
#
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/kaufmann-dev/git-wrangler/main/install | bash
# ──────────────────────────────────────────────────────────────────────────────

set -euo pipefail

INSTALL_DIR="$HOME/.wrangler"
REPO_URL="https://github.com/kaufmann-dev/git-wrangler.git"

fatal() { printf "\e[31m✖ %s\e[0m\n" "$1" >&2; exit 1; }

# Prefer ~/.local/bin (XDG-ish, no sudo), fall back to /usr/local/bin on macOS.
resolve_bin_dir() {
    local local_bin="$HOME/.local/bin"
    if [ -d "$local_bin" ]; then
        printf '%s' "$local_bin"
    elif [ -d "/usr/local/bin" ] && [ -w "/usr/local/bin" ]; then
        printf '%s' "/usr/local/bin"
    else
        printf '%s' "$local_bin"
    fi
}

main() {
    printf "\n\e[1mGit Wrangler — Installer\e[0m\n\n"

    # ── Prerequisites ────────────────────────────────────────────────────

    if ! command -v git &>/dev/null; then
        fatal "git is required but was not found. Install it first: https://git-scm.com"
    fi

    # ── Already installed? ───────────────────────────────────────────────

    if [ -d "$INSTALL_DIR/.git" ]; then
        printf "\e[32m✔ Git Wrangler is already installed at %s\e[0m\n\n" "$INSTALL_DIR"
        printf "  To update, run:    \e[1mwrangler update\e[0m\n"
        printf "  To uninstall, run: \e[1mwrangler uninstall\e[0m\n\n"
        exit 0
    elif [ -d "$INSTALL_DIR" ]; then
        fatal "$INSTALL_DIR already exists but is not a git repository. Remove it manually and re-run."
    fi

    # ── Clone ────────────────────────────────────────────────────────────

    printf "\e[1m\e[36m▸\e[0m Cloning repository…\n"
    if clone_output=$(git clone --depth 1 --branch main "$REPO_URL" "$INSTALL_DIR" 2>&1); then
        printf "\e[32m✔ Cloned successfully\e[0m\n"
    else
        printf "\e[31m✖ Failed to clone repository:\n%s\e[0m\n" "$clone_output" >&2
        exit 1
    fi

    # ── Make scripts executable ──────────────────────────────────────────

    chmod +x "$INSTALL_DIR/wrangler" 2>/dev/null || true
    chmod +x "$INSTALL_DIR"/libexec/wrangler-* 2>/dev/null || true

    # ── Create symlink ───────────────────────────────────────────────────

    local bin_dir
    bin_dir="$(resolve_bin_dir)"

    if [ ! -d "$bin_dir" ]; then
        printf "\e[1m\e[36m▸\e[0m Creating %s\n" "$bin_dir"
        mkdir -p "$bin_dir"
    fi

    local link_target="$bin_dir/wrangler"

    if [ -L "$link_target" ]; then
        ln -sf "$INSTALL_DIR/wrangler" "$link_target"
    elif [ -e "$link_target" ]; then
        fatal "A file already exists at $link_target (not a symlink). Remove it manually and re-run."
    else
        ln -s "$INSTALL_DIR/wrangler" "$link_target"
    fi

    printf "\e[32m✔ Symlinked to %s\e[0m\n" "$link_target"

    # ── Done ─────────────────────────────────────────────────────────────

    printf "\n\e[32m✔ Git Wrangler installed successfully!\e[0m\n\n"

    case ":$PATH:" in
        *":$bin_dir:"*) ;;
        *)
            printf "\e[33m⚠ %s is not in your \$PATH.\e[0m\n\n" "$bin_dir"
            printf "  Add it to your shell profile:\n\n"
            printf "    export PATH=\"%s:\$PATH\"\n\n" "$bin_dir"
            printf "  Then restart your terminal.\n\n"
            ;;
    esac

    printf "  Run \e[1mwrangler help\e[0m to get started.\n\n"
}

main "$@"
