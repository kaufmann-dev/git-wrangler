---
// DocsLayout.astro – Documentation page layout with sidebar
import BaseLayout from './BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  currentSlug?: string;
}

const { title, description, currentSlug } = Astro.props;

// Load all docs to build the sidebar dynamically
const allDocs = await getCollection('docs');

// Sort entries: put General / meta pages first, then alphabetically within category
const categoryOrder = ['General', 'Utility', 'Local Operations', 'Remote Operations', 'AI Commands', 'History Rewriting'];

const grouped: Record<string, typeof allDocs> = {};
for (const doc of allDocs) {
  const cat = doc.data.category || 'General';
  if (!grouped[cat]) grouped[cat] = [];
  grouped[cat].push(doc);
}

// Sort pages within each group by order then title
for (const cat of Object.keys(grouped)) {
  grouped[cat].sort((a, b) => {
    const ao = a.data.order ?? 999;
    const bo = b.data.order ?? 999;
    if (ao !== bo) return ao - bo;
    return a.data.title.localeCompare(b.data.title);
  });
}

const orderedCategories = categoryOrder.filter(c => grouped[c]);
---

<BaseLayout title={title} description={description}>
  <Navbar />
  <div class="docs-layout">
    <Sidebar grouped={grouped} orderedCategories={orderedCategories} currentSlug={currentSlug} />
    <main class="docs-main" id="main-content">
      <article class="docs-article prose">
        <slot />
      </article>
    </main>
  </div>
  <Footer />
  <script>
    function wrapCodeBlocks() {
      document.querySelectorAll('.prose pre').forEach((pre) => {
        // Prevent double-wrapping during ViewTransitions
        if (pre.parentElement?.classList.contains('terminal-body')) return;

        // Create terminal container
        const terminal = document.createElement('div');
        terminal.className = 'terminal';
        terminal.style.marginBottom = 'var(--space-6)';

        // Create terminal bar with dots
        const bar = document.createElement('div');
        bar.className = 'terminal-bar';
        bar.innerHTML = `
          <span class="terminal-dot terminal-dot--red"></span>
          <span class="terminal-dot terminal-dot--yellow"></span>
          <span class="terminal-dot terminal-dot--green"></span>
        `;

        // Create terminal body
        const body = document.createElement('div');
        body.className = 'terminal-body';
        
        // Reset pre styles since terminal wrapper handles them
        (pre as HTMLElement).style.margin = '0';
        (pre as HTMLElement).style.boxShadow = 'none';
        (pre as HTMLElement).style.borderRadius = '0';
        (pre as HTMLElement).style.backgroundColor = 'transparent';

        // Assemble
        pre.parentNode?.insertBefore(terminal, pre);
        body.appendChild(pre);
        terminal.appendChild(bar);
        terminal.appendChild(body);
      });
    }

    // Run on initial load and after every ViewTransition
    document.addEventListener('astro:page-load', wrapCodeBlocks);
  </script>
</BaseLayout>

<style>
  .docs-layout {
    display: grid;
    grid-template-columns: var(--sidebar-width) 1fr;
    min-height: calc(100vh - var(--nav-height));
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding-top: var(--nav-height);
  }

  .docs-main {
    min-width: 0;
    padding: var(--space-8) var(--space-8) var(--space-11);
    border-left: 1px solid var(--color-gray-100);
  }

  .docs-article {
    max-width: 72ch;
  }

  @media (max-width: 768px) {
    .docs-layout {
      grid-template-columns: 1fr;
    }

    .docs-main {
      padding: var(--space-6);
      border-left: none;
    }
  }
</style>
