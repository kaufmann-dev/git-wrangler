---
// BaseLayout.astro – Root layout with ViewTransitions
import { ClientRouter } from 'astro:transitions';
import '@fontsource/geist/400.css';
import '@fontsource/geist/500.css';
import '@fontsource/geist/600.css';
import '@fontsource/geist-mono/400.css';
import '@fontsource/geist-mono/500.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogType?: string;
}

const {
  title,
  description = 'Git Wrangler – A command-line orchestrator that broadcasts Git operations across an entire directory of repositories simultaneously.',
  ogType = 'website',
} = Astro.props;

const fullTitle = title === 'Git Wrangler'
  ? 'Git Wrangler'
  : `${title} – Git Wrangler`;
const siteURL = Astro.site ?? new URL('https://git-wrangler.kaufmann.dev');
const canonicalPath = Astro.url.pathname.replace(/\/{2,}/g, '/');
const canonicalURL = new URL(canonicalPath, siteURL).href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content="/git-wrangler.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/git-wrangler.png" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalURL} />
    <title>{fullTitle}</title>
    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>
