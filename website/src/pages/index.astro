---
// src/pages/index.astro – Landing Page
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import FeaturesSection from '../components/FeaturesSection.astro';
import QuickStart from '../components/QuickStart.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Git Wrangler"
  description="Git Wrangler – A command-line orchestrator that broadcasts Git operations from simple pulls to complex history rewrites across an entire directory of repositories simultaneously."
>
  <Navbar />

  <main id="main-content">
    <Hero />
    <FeaturesSection />
    <QuickStart />

    <!-- Final CTA banner -->
    <section class="cta-banner">
      <div class="container cta-banner-inner">
        <div class="cta-banner-text">
          <h2 class="text-subheading">Ready to wrangle your repos?</h2>
          <p class="text-body cta-banner-desc">
            One command to install. Dozens of repos under control.
          </p>
        </div>
        <div class="cta-banner-actions">
          <a href="/docs/installation" class="btn-primary cta-banner-btn" id="cta-banner-install">
            Install Now
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4"/>
            </svg>
          </a>
          <a href="/docs/introduction" class="btn-secondary" id="cta-banner-docs">Read the Docs</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .cta-banner {
    border-top: 1px solid var(--color-gray-100);
    padding-block: var(--space-10);
  }

  .cta-banner-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-7);
    flex-wrap: wrap;
  }

  .cta-banner-desc {
    margin-top: var(--space-3);
    max-width: 400px;
  }

  .cta-banner-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .cta-banner-btn {
    padding: 10px 20px;
    font-size: 0.9375rem;
  }

  @media (max-width: 600px) {
    .cta-banner-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .cta-banner {
      padding-block: var(--space-8);
    }
  }
</style>
