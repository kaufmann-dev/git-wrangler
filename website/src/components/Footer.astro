---
// Footer.astro – Site footer
---

<footer class="footer">
  <div class="footer-bottom container">
    <p class="footer-copy">
      &copy; {new Date().getFullYear()} Git Wrangler. MIT License.
    </p>
    <div class="footer-links">
      <a href="https://legal.kaufmann.dev/imprint?site=wrangler.kaufmann.dev" class="footer-link" target="_blank" rel="noopener noreferrer">Imprint</a>
      <span class="footer-sep" aria-hidden="true">&bull;</span>
      <a href="https://wrangler.kaufmann.dev/privacy?site=wrangler.kaufmann.dev" class="footer-link" target="_blank" rel="noopener noreferrer">Privacy</a>
      <span class="footer-sep" aria-hidden="true">&bull;</span>
      Built with
      <a href="https://astro.build" class="footer-link" target="_blank" rel="noopener noreferrer">Astro</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-gray-100);
    background: var(--color-white);
  }

  .footer-bottom {
    padding-block: var(--space-5);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
  }

  .footer-copy {
    font-size: 0.75rem;
    color: var(--color-gray-400);
    line-height: 1.5;
  }

  .footer-links {
    font-size: 0.75rem;
    color: var(--color-gray-400);
    line-height: 1.5;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem;
  }

  .footer-sep {
    color: var(--color-gray-300);
    user-select: none;
  }

  .footer-link {
    color: var(--color-gray-500);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-link:hover {
    color: var(--color-black);
  }

  @media (max-width: 768px) {
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
