---
// FeaturesSection.astro – Features grid section on the landing page
import FeatureCard from './FeatureCard.astro';

const features = [
  {
    title: 'Multi-Repo Management',
    description: 'Run common Git workflows across every repository in a directory with a single command and deterministic output.',
  },
  {
    title: 'History Rewriting',
    description: 'Safely rewrite authors, commit messages, timestamps, and purge secrets across all repos at once — powered by git-filter-repo.',
  },
  {
    title: 'Native Go CLI',
    description: 'A compiled Cobra command surface with built-in help, version metadata, and shell completions.',
  },
  {
    title: 'Smart Status Dashboard',
    description: 'Instant at-a-glance view of every repo\'s dirty/clean state, ahead/behind counts, and remote tracking status.',
  },
  {
    title: 'Homebrew Releases',
    description: 'GoReleaser publishes checksums, GitHub Release binaries, completions, and Homebrew tap updates.',
  },
  {
    title: 'Cross-Platform',
    description: 'Distributed as native macOS, Linux, and Windows binaries, with Homebrew as the primary install path.',
  },
];
---

<section class="features-section" id="features">
  <div class="container">
    <div class="features-header">
      <h2 class="text-section-heading">Everything you need,<br />nothing you don't.</h2>
      <p class="text-body-large features-subhead">
        A lean compiled CLI with focused internal packages, native help, and repeatable releases.
      </p>
    </div>

    <div class="features-grid">
      {features.map((f) => (
        <FeatureCard
          title={f.title}
          description={f.description}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    padding-block: var(--space-11);
    border-top: 1px solid var(--color-gray-100);
  }

  .features-header {
    text-align: center;
    margin-bottom: var(--space-10);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .features-subhead {
    max-width: 480px;
    color: var(--color-gray-600);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  @media (max-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .features-grid {
      grid-template-columns: 1fr;
    }

    .features-section {
      padding-block: var(--space-8);
    }
  }
</style>
