---
// FeaturesSection.astro – Features grid section on the landing page
import FeatureCard from './FeatureCard.astro';

const features = [
  {
    title: 'Multi-Repo Management',
    description: 'Run any Git operation across every repository in a directory with a single command. Status, pull, commit, push — all in parallel.',
    accentColor: 'var(--color-develop)',
  },
  {
    title: 'History Rewriting',
    description: 'Safely rewrite authors, commit messages, timestamps, and purge secrets across all repos at once — powered by git-filter-repo.',
    accentColor: 'var(--color-ship)',
  },
  {
    title: 'Subshell Isolation',
    description: 'Each repository operation runs in its own subshell. Directory changes and variables never leak, guaranteeing predictable results.',
    accentColor: 'var(--color-preview)',
  },
  {
    title: 'Smart Status Dashboard',
    description: 'Instant at-a-glance view of every repo\'s dirty/clean state, ahead/behind counts, and remote tracking status.',
    accentColor: 'var(--color-develop)',
  },
  {
    title: 'Dynamic Help System',
    description: 'No central registry. The help menu is auto-generated by parsing structured metadata headers in each script — forever zero-maintenance.',
    accentColor: 'var(--color-preview)',
  },
  {
    title: 'Cross-Platform',
    description: 'Works natively on macOS, Linux, and Windows via Git Bash or WSL. One install command, works everywhere.',
    accentColor: 'var(--color-ship)',
  },
];
---

<section class="features-section" id="features">
  <div class="container">
    <div class="features-header">
      <h2 class="text-section-heading">Everything you need,<br />nothing you don't.</h2>
      <p class="text-body-large features-subhead">
        A lean, modular bash architecture — every command is a self-contained script,
        every operation is sandboxed.
      </p>
    </div>

    <div class="features-grid">
      {features.map((f) => (
        <FeatureCard
          title={f.title}
          description={f.description}
          accentColor={f.accentColor}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    padding-block: var(--space-11);
    border-top: 1px solid var(--color-gray-100);
  }

  .features-header {
    text-align: center;
    margin-bottom: var(--space-10);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .features-subhead {
    max-width: 480px;
    color: var(--color-gray-600);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  @media (max-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .features-grid {
      grid-template-columns: 1fr;
    }

    .features-section {
      padding-block: var(--space-8);
    }
  }
</style>
