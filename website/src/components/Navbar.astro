---
// Navbar.astro – Sticky top navigation bar
const currentPath = Astro.url.pathname;

const isActive = (path: string) =>
  currentPath === path || (path !== '/' && currentPath.startsWith(path));
---

<header class="navbar" id="navbar">
  <div class="navbar-inner container">
    <!-- Logo + Brand -->
    <a href="/" class="navbar-brand" aria-label="Git Wrangler Home">
      <img src="/favicon.svg" alt="Git Wrangler logo" class="navbar-logo" width="28" height="21" />
      <span class="navbar-wordmark">git-wrangler</span>
    </a>

    <!-- Primary navigation -->
    <nav class="navbar-nav" aria-label="Primary navigation">
      <a href="/#features" class="navbar-link">Features</a>
      <a href="/docs/introduction" class={`navbar-link ${isActive('/docs') ? 'navbar-link--active' : ''}`}>Docs</a>
    </nav>

    <!-- CTAs -->
    <div class="navbar-actions">
      <a
        href="https://github.com/kaufmann-dev/git-wrangler"
        class="btn-secondary navbar-cta-ghost"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="View on GitHub"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        GitHub
      </a>
      <a href="/docs/installation" class="btn-primary navbar-cta">
        Get Started
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4"/>
        </svg>
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button class="navbar-hamburger" id="navbar-toggle" aria-label="Toggle navigation menu" aria-expanded="false">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="navbar-mobile-menu" id="navbar-mobile-menu" hidden>
    <nav class="mobile-nav" aria-label="Mobile navigation">
      <a href="/#features" class="mobile-nav-link">Features</a>
      <a href="/docs/introduction" class="mobile-nav-link">Docs</a>
      <a href="https://github.com/kaufmann-dev/git-wrangler" class="mobile-nav-link" target="_blank" rel="noopener noreferrer">GitHub</a>
      <div class="mobile-nav-actions">
        <a href="/docs/installation" class="btn-primary" style="width: 100%; justify-content: center;">Get Started</a>
      </div>
    </nav>
  </div>
</header>

<script>
  // Hamburger menu toggle
  const toggle = document.getElementById('navbar-toggle');
  const menu = document.getElementById('navbar-mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.hidden;
    if (menu) menu.hidden = isOpen;
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.classList.toggle('is-open', !isOpen);
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!toggle?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
      if (menu) menu.hidden = true;
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.classList.remove('is-open');
    }
  });

  // Scroll effect
  const navbar = document.getElementById('navbar');
  const onScroll = () => {
    navbar?.classList.toggle('navbar--scrolled', window.scrollY > 8);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-height);
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .navbar--scrolled {
    border-bottom-color: var(--color-gray-100);
    background: rgba(255, 255, 255, 0.95);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    gap: var(--space-7);
    height: 100%;
  }

  /* Brand */
  .navbar-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .navbar-logo {
    display: block;
    width: 28px;
    height: auto;
  }

  .navbar-wordmark {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-black);
    letter-spacing: -0.02em;
  }

  /* Nav links */
  .navbar-nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex: 1;
  }

  .navbar-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-gray-600);
    text-decoration: none;
    transition: color 0.15s ease;
    padding: 4px 0;
    position: relative;
  }

  .navbar-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--color-black);
    transform: scaleX(0);
    transition: transform 0.2s ease;
  }

  .navbar-link:hover {
    color: var(--color-black);
  }

  .navbar-link:hover::after,
  .navbar-link--active::after {
    transform: scaleX(1);
  }

  .navbar-link--active {
    color: var(--color-black);
    font-weight: 600;
    letter-spacing: -0.32px;
  }

  /* Actions */
  .navbar-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-shrink: 0;
  }

  .navbar-cta-ghost {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  /* Hamburger */
  .navbar-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 6px;
    background: none;
    border: none;
    border-radius: var(--radius-standard);
    cursor: pointer;
    transition: background 0.15s;
  }

  .navbar-hamburger:hover {
    background: var(--color-gray-50);
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 1.5px;
    background: var(--color-black);
    border-radius: 1px;
    transition: transform 0.2s ease, opacity 0.2s ease;
    transform-origin: center;
  }

  .navbar-hamburger.is-open .hamburger-line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .navbar-hamburger.is-open .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .navbar-hamburger.is-open .hamburger-line:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* Mobile menu */
  .navbar-mobile-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--color-white);
    border-bottom: 1px solid var(--color-gray-100);
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    padding: var(--space-5) var(--space-6) var(--space-6);
    gap: var(--space-4);
  }

  .mobile-nav-link {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-black);
    text-decoration: none;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-gray-100);
  }

  .mobile-nav-actions {
    margin-top: var(--space-4);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .navbar-nav,
    .navbar-actions {
      display: none;
    }

    .navbar-hamburger {
      display: flex;
    }

    .navbar-inner {
      justify-content: space-between;
    }
  }
</style>
