---
// Sidebar.astro – Documentation left sidebar, dynamically generated from content collections
import type { CollectionEntry } from 'astro:content';

interface Props {
  grouped: Record<string, CollectionEntry<'docs'>[]>;
  orderedCategories: string[];
  currentSlug?: string;
}

const { grouped, orderedCategories, currentSlug } = Astro.props;

---

<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <button class="sidebar-close" id="sidebar-close" aria-label="Close documentation menu">
      <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3.5 6l4.5 4.5L12.5 6"/>
      </svg>
      <span>Menu</span>
    </button>
  </div>

  <nav class="sidebar-nav" aria-label="Documentation navigation">
    {orderedCategories.map((cat) => (
      <div class="sidebar-group">
        <div class="sidebar-group-label">
          <span>{cat}</span>
        </div>
        <ul class="sidebar-list">
          {grouped[cat].map((doc) => {
            const slug = doc.id;
            const isActive = currentSlug === slug;
            return (
              <li>
                <a
                  href={`/docs/${slug}`}
                  class={`sidebar-link ${isActive ? 'sidebar-link--active' : ''}`}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {doc.data.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>
</aside>

<!-- Mobile overlay -->
<div class="sidebar-overlay" id="sidebar-overlay"></div>

<!-- Mobile toggle button (rendered in page) -->
<button class="sidebar-mobile-toggle" id="sidebar-mobile-toggle" aria-label="Open documentation menu" aria-expanded="false" aria-controls="sidebar">
  <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M6 3.5L10.5 8L6 12.5"/>
  </svg>
  <span>Menu</span>
</button>

<script>
  const win = window as Window & { __docsSidebarCleanup?: () => void };

  function setupDocsSidebar() {
    win.__docsSidebarCleanup?.();

    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    const toggleBtn = document.getElementById('sidebar-mobile-toggle');
    const closeBtn = document.getElementById('sidebar-close');
    const links = sidebar?.querySelectorAll('a');

    if (!sidebar || !overlay || !toggleBtn || !closeBtn) return;

    const openSidebar = () => {
      sidebar.classList.add('sidebar--open');
      overlay.classList.add('sidebar-overlay--visible');
      toggleBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    };

    const closeSidebar = () => {
      sidebar.classList.remove('sidebar--open');
      overlay.classList.remove('sidebar-overlay--visible');
      toggleBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    };

    const handleKeydown = (e: KeyboardEvent) => {
      if (e.key === 'Escape') closeSidebar();
    };

    const handleResize = () => {
      if (window.innerWidth > 768) closeSidebar();
    };

    toggleBtn.addEventListener('click', openSidebar);
    closeBtn.addEventListener('click', closeSidebar);
    overlay.addEventListener('click', closeSidebar);
    document.addEventListener('keydown', handleKeydown);
    window.addEventListener('resize', handleResize);
    links?.forEach((link) => link.addEventListener('click', closeSidebar));

    win.__docsSidebarCleanup = () => {
      closeSidebar();
      toggleBtn.removeEventListener('click', openSidebar);
      closeBtn.removeEventListener('click', closeSidebar);
      overlay.removeEventListener('click', closeSidebar);
      document.removeEventListener('keydown', handleKeydown);
      window.removeEventListener('resize', handleResize);
      links?.forEach((link) => link.removeEventListener('click', closeSidebar));
    };
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupDocsSidebar, { once: true });
  } else {
    setupDocsSidebar();
  }

  document.addEventListener('astro:page-load', setupDocsSidebar);
</script>

<style>
  .sidebar {
    position: sticky;
    top: var(--nav-height);
    height: calc(100vh - var(--nav-height));
    overflow-y: auto;
    padding: var(--space-6) 0;
    scrollbar-width: thin;
    scrollbar-color: var(--color-gray-100) transparent;
  }

  .sidebar-header {
    display: none;
    border-bottom: 1px solid var(--color-gray-100);
  }

  .sidebar-close {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    width: 100%;
    min-height: 56px;
    padding: 0 var(--space-7);
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-black);
    background: var(--color-white);
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background 0.15s ease;
  }

  .sidebar-close:hover {
    background: var(--color-gray-50);
    color: var(--color-black);
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    padding: 0 var(--space-6);
  }

  .sidebar-group-label {
    display: flex;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.45;
    text-transform: none;
    letter-spacing: 0;
    color: var(--color-black);
    margin-bottom: var(--space-4);
    padding: 0;
  }

  .sidebar-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .sidebar-link {
    display: block;
    padding: 0;
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-gray-500);
    text-decoration: none;
    transition: background 0.1s ease, color 0.1s ease;
    line-height: 1.55;
  }

  .sidebar-link:hover {
    background: transparent;
    color: var(--color-black);
  }

  .sidebar-link--active {
    background: transparent;
    color: var(--color-link);
    font-weight: 500;
    letter-spacing: 0;
    box-shadow: none;
  }

  /* Mobile toggle */
  .sidebar-mobile-toggle {
    display: none;
    align-items: center;
    gap: var(--space-5);
    min-height: 56px;
    padding: 0 var(--space-7);
    margin: 0;
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-black);
    background: var(--color-white);
    border: none;
    border-bottom: 1px solid var(--color-gray-100);
    cursor: pointer;
    width: 100%;
    text-align: left;
    transition: background 0.15s ease;
  }

  .sidebar-mobile-toggle:hover {
    background: var(--color-gray-50);
  }

  /* Overlay */
  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    z-index: 49;
    opacity: 0;
    transition: opacity 0.2s;
  }

  @media (max-width: 768px) {
    .sidebar {
      position: fixed;
      top: var(--nav-height);
      left: 0;
      right: 0;
      bottom: 0;
      width: 100%;
      height: calc(100vh - var(--nav-height));
      background: var(--color-white);
      z-index: 90;
      padding: 0;
      border-right: none;
      transform: translateY(-8px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s ease, transform 0.2s ease;
      box-shadow: none;
    }

    .sidebar--open {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .sidebar-header {
      display: flex;
    }

    .sidebar-nav {
      gap: var(--space-8);
      height: calc(100% - 56px);
      overflow-y: auto;
      padding: var(--space-6) var(--space-7) var(--space-8);
    }

    .sidebar-group-label {
      font-family: var(--font-sans);
      font-size: 1rem;
      font-weight: 600;
      line-height: 1.5;
      text-transform: none;
      letter-spacing: 0;
      color: var(--color-black);
      margin-bottom: var(--space-4);
      padding: 0;
    }

    .sidebar-list {
      gap: var(--space-4);
    }

    .sidebar-link {
      padding: 0;
      font-size: 1rem;
      line-height: 1.55;
      color: var(--color-gray-500);
      border-radius: 0;
    }

    .sidebar-link:hover {
      background: transparent;
      color: var(--color-black);
    }

    .sidebar-link--active {
      background: transparent;
      color: var(--color-link);
      box-shadow: none;
      font-weight: 500;
    }

    .sidebar-overlay {
      display: none;
    }

    .sidebar-overlay--visible {
      opacity: 1;
    }

    .sidebar-mobile-toggle {
      display: flex;
    }
  }

  @media (max-width: 420px) {
    .sidebar-close,
    .sidebar-mobile-toggle {
      padding-inline: var(--space-6);
    }

    .sidebar-nav {
      padding-inline: var(--space-6);
    }
  }
</style>
