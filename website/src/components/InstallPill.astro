---
// src/components/InstallPill.astro
const command = "brew install --cask kaufmann-dev/tap/git-wrangler";
---

<div class="install-pill-container" id="install-pill">
  <div class="install-pill">
    <span class="prefix">$</span>
    <code class="command">{command}</code>
    <button class="copy-button" aria-label="Copy to clipboard" id="copy-btn">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-copy">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
      </svg>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-check" style="display: none;">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </button>
  </div>
  <span id="copy-announcement" class="sr-only" aria-live="polite"></span>
</div>

<script is:inline define:vars={{ command }}>
  const copyBtn = document.getElementById('copy-btn');
  const iconCopy = copyBtn.querySelector('.icon-copy');
  const iconCheck = copyBtn.querySelector('.icon-check');
  const announcement = document.getElementById('copy-announcement');

  copyBtn.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(command);
      
      // Feedback
      iconCopy.style.display = 'none';
      iconCheck.style.display = 'block';
      copyBtn.classList.add('success');
      announcement.textContent = 'Copied to clipboard';
      
      setTimeout(() => {
        iconCopy.style.display = 'block';
        iconCheck.style.display = 'none';
        copyBtn.classList.remove('success');
        announcement.textContent = '';
      }, 2000);
    } catch (err) {
      console.error('Failed to copy: ', err);
    }
  });
</script>

<style>
  .install-pill-container {
    width: 100%;
    display: flex;
    justify-content: center;
    animation: fade-in 0.6s ease 0.2s both;
  }

  .install-pill {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: 12px 24px;
    background: var(--color-white);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-border), var(--shadow-subtle);
    max-width: 100%;
    transition: box-shadow 0.2s ease;
  }

  .install-pill:hover {
    box-shadow: rgba(0, 0, 0, 0.16) 0px 0px 0px 1px, var(--shadow-card);
  }

  .prefix {
    color: var(--color-gray-400);
    font-family: var(--font-mono);
    font-size: 1.125rem;
    user-select: none;
  }

  .command {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    color: var(--color-black);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    /* Prevent shrinking too much */
    min-width: 0;
    /* Override global code styles */
    background: none;
    box-shadow: none;
    padding: 0;
  }

  .copy-button {
    background: none;
    border: none;
    padding: 4px;
    margin-left: 4px;
    cursor: pointer;
    color: var(--color-gray-400);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s ease, transform 0.1s ease;
    flex-shrink: 0;
  }

  .copy-button:hover {
    color: var(--color-black);
  }

  .copy-button:active {
    transform: scale(0.9);
  }

  .copy-button.success {
    color: var(--color-success);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 768px) {
    .install-pill {
      padding: 10px 18px;
      gap: var(--space-3);
      width: 100%;
    }
    
    .command {
      font-size: 0.8125rem;
    }
  }

  /* Specific mobile truncation as seen in the image */
  @media (max-width: 480px) {
    .install-pill {
      max-width: 90vw;
    }
  }
</style>
