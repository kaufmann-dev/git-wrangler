---
// FeatureCard.astro – A single feature card
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<div class="feature-card card">
  <div class="feature-card-content">
    <h3 class="text-card-title feature-card-title">{title}</h3>
    <p class="feature-card-desc">{description}</p>
  </div>
</div>

<style>
  .feature-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    cursor: default;
  }

  .feature-card-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .feature-card-title {
    margin: 0;
  }

  .feature-card-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-gray-600);
    margin: 0;
  }
</style>
